---
import { clothing, site } from "../../data/content.ts";
import { withBase } from "../../lib/url.ts";
import ScrollCue from "../ScrollCue.astro";
const { featured, designers } = clothing;
const num = (i: number) => String(i + 1).padStart(2, "0");
// every designer links out to their results on the live Shopify store
const searchUrl = (name: string) => `${site.shopUrl}/search?q=${encodeURIComponent(name)}`;
---
<section class="block" id="clothing">
  <div class="left">
    <img src={withBase("/images/blocks/clothing.jpg")} alt="garments on the rack" />
    <div class="tint"></div>
    <div class="swingtag">
      <span class="punch"></span>
      <div class="name">{featured.name}</div>
      <div class="cloth">{featured.cloth}</div>
      <dl>
        {featured.details.map((d) => (
          <>
            <dt>{d.label}</dt><dd>{d.value}</dd>
          </>
        ))}
      </dl>
    </div>
    <div class="rackhint">{clothing.rackHint}</div>
  </div>

  <div class="right">
    <div class="kicker">{clothing.kicker}</div>
    <div class="title">{clothing.title}</div>

    <div class="idxhead">
      <button class="idxctl on" data-sort="az">a–z</button>
      <button class="idxctl" data-sort="za">z–a</button>
      <button class="idxctl" id="idxFilterBtn">filter</button>
      <span class="idxcount"><span id="idxCount">{designers.length}</span> designers</span>
    </div>

    <input id="idxSearch" class="idxsearch" type="text" placeholder="type a name…" autocomplete="off" hidden />

    <div class="idxcols" id="idxList">
      {designers.map((name, i) => (
        <a class="row" href={searchUrl(name)} target="_blank" rel="noopener" data-name={name.toLowerCase()}>
          <span class="num">{num(i)}</span><span class="nm">{name}</span>
        </a>
      ))}
    </div>
    <ScrollCue />
  </div>
</section>

<script>
  // Living directory: a–z / z–a sort + live filter, renumbering as it changes.
  const list = document.getElementById("idxList");
  const search = document.getElementById("idxSearch") as HTMLInputElement | null;
  const countEl = document.getElementById("idxCount");
  const filterBtn = document.getElementById("idxFilterBtn");

  if (list) {
    const renumber = () => {
      let n = 0;
      Array.from(list.children).forEach((r) => {
        const el = r as HTMLElement;
        if (el.style.display !== "none") {
          n += 1;
          const num = el.querySelector(".num");
          if (num) num.textContent = String(n).padStart(2, "0");
        }
      });
      if (countEl) countEl.textContent = String(n);
    };

    const sort = (dir: string) => {
      const rows = Array.from(list.querySelectorAll<HTMLElement>(".row"));
      rows
        .sort((a, b) => (a.dataset.name || "").localeCompare(b.dataset.name || "") * (dir === "za" ? -1 : 1))
        .forEach((r) => list.appendChild(r));
      renumber();
    };

    document.querySelectorAll<HTMLElement>(".idxctl[data-sort]").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".idxctl[data-sort]").forEach((b) => b.classList.remove("on"));
        btn.classList.add("on");
        sort(btn.dataset.sort || "az");
      });
    });

    filterBtn?.addEventListener("click", () => {
      if (!search) return;
      if (search.hasAttribute("hidden")) {
        search.removeAttribute("hidden");
        search.focus();
        filterBtn.classList.add("on");
      } else {
        search.setAttribute("hidden", "");
        search.value = "";
        list.querySelectorAll<HTMLElement>(".row").forEach((r) => (r.style.display = ""));
        renumber();
        filterBtn.classList.remove("on");
      }
    });

    search?.addEventListener("input", () => {
      const q = search.value.trim().toLowerCase();
      list.querySelectorAll<HTMLElement>(".row").forEach((r) => {
        r.style.display = (r.dataset.name || "").includes(q) ? "" : "none";
      });
      renumber();
    });
  }
</script>

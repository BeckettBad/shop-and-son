---
import { music } from "../../data/content.ts";
import { withBase } from "../../lib/url.ts";
const { nowPlaying, tracks } = music;
const tn = (i: number) => String(i + 1).padStart(2, "0");
---
<section class="block" id="music">
  <div class="left">
    <img src={withBase("/images/blocks/music.jpg")} alt="the in-store speaker" />
    <div class="tint"></div>
    <div class="woofer"></div>
    <div class="rackhint">{music.rackHint}</div>
  </div>
  <div class="right">
    <div class="kicker">{music.kicker}</div>
    <div class="title" set:html={music.title} />
    <div class="nowplaying">
      <div class="bt"><span>{nowPlaying.label}</span><span>{nowPlaying.time}</span></div>
      <div class="song">{nowPlaying.song}</div>
      <div class="artist">{nowPlaying.artist}</div>
      <div class="eq"><i></i><i></i><i></i><i></i><i></i></div>
    </div>
    <div class="tracklist">
      {tracks.map((t, i) => (
        <div class="t"><span class="tn">{tn(i)}</span><span class="serif-it">{t}</span></div>
      ))}
    </div>
    <div class="dispatch">{music.dispatch}</div>
    <div class="scroll-hint"><span class="scroll-hint__arrow">↓</span></div>
  </div>
</section>

<script>
  // the woofer "wakes up" only while the music block is on screen
  const wf = document.querySelector<HTMLElement>(".woofer");
  const music = document.getElementById("music");
  if (wf && music) {
    new IntersectionObserver(
      (entries) => entries.forEach((e) => { wf.style.opacity = e.isIntersecting ? "1" : "0"; }),
      { threshold: 0.4 },
    ).observe(music);
  }
</script>

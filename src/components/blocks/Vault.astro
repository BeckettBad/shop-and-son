---
import { vault } from "../../data/content.ts";
import { withBase } from "../../lib/url.ts";
import ScrollCue from "../ScrollCue.astro";
---
<section class="block vault" id="vault">
  <div class="left" id="flashzone">
    <img src={withBase("/images/blocks/vault.jpg")} alt="the lower-level vault" />
    <div class="flash"></div>
    <div class="neon">{vault.neon}</div>
    <div class="rackhint">{vault.rackHint}</div>
  </div>
  <div class="right">
    <div class="kicker">{vault.kicker}</div>
    <div class="title">{vault.title}</div>
    <div class="vaultcard">
      <div class="key" set:html={vault.key} />
      <p class="lede" style="margin-top:10px" set:html={vault.ledeHtml} />
      <span class="instore">{vault.badge}</span>
    </div>
    <div class="meta">{vault.meta}</div>
    <ScrollCue />
  </div>
</section>

<script>
  // the flashlight follows the cursor across the vault photo
  const fz = document.getElementById("flashzone");
  const fl = fz?.querySelector<HTMLElement>(".flash");
  if (fz && fl) {
    fz.addEventListener("mousemove", (e) => {
      const r = fz.getBoundingClientRect();
      fl.style.setProperty("--mx", ((e.clientX - r.left) / r.width) * 100 + "%");
      fl.style.setProperty("--my", ((e.clientY - r.top) / r.height) * 100 + "%");
    });
  }
</script>

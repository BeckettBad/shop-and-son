# Shopify Storefront API (read-only) — see src/lib/shopify.ts
# Copy this file to `.env` and fill in. `.env` is gitignored.

# Your store domain. Either the custom domain or the *.myshopify.com domain.
SHOPIFY_STORE_DOMAIN=shopandson.com

# Public Storefront API access token:
# Shopify admin → Settings → Apps and sales channels → Develop apps
#   → (create/select an app) → Storefront API → install → copy the token.
# Enable at least: unauthenticated_read_product_listings, unauthenticated_read_product_inventory.
SHOPIFY_STOREFRONT_API_TOKEN=

# Optional — defaults to 2025-01 if unset.
SHOPIFY_STOREFRONT_API_VERSION=2025-01

---
import "../styles/global.css";
import { site } from "../data/content.ts";
import { PRODUCTION_COLLECTOR_ENDPOINT } from "../lib/analytics";
import { withBase } from "../lib/url.ts";

interface Props {
  title?: string;
  description?: string;
  /** Opening splash only — no header, no scroll, no index overlay. */
  landing?: boolean;
  /** Minimal chrome-free layout that still scrolls normally. */
  bare?: boolean;
}
const {
  title = `${site.brand} — independent design`,
  description = "&son is an independent design shop at 138 Sullivan St, SoHo, New York. Clothing and objects from independent designers, curated by Ben.",
  landing = false,
} = Astro.props;
const preloadHeroPoster = landing;
const siteUrl = Astro.site ?? new URL("https://beckettbad.github.io");
const absolutePageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteOgImageUrl = new URL(withBase("/og-image.jpg"), siteUrl).toString();
const nowPlayingUrl = import.meta.env.PUBLIC_NOW_PLAYING_URL?.trim() ?? "";
const configuredOperationsEventsUrl = import.meta.env.PUBLIC_OPERATIONS_EVENTS_URL?.trim() ?? "";
const operationsEventsUrl = configuredOperationsEventsUrl === PRODUCTION_COLLECTOR_ENDPOINT
  ? PRODUCTION_COLLECTOR_ENDPOINT
  : "";
const shopifyDomain = (import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN?.trim() || "shopandson.com")
  .replace(/^https?:\/\//, "")
  .replace(/\/+$/, "");
const shopifyOrigin = `https://${shopifyDomain}`;
let nowPlayingOrigin = "";
let operationsOrigin = "";
if (nowPlayingUrl) {
  try {
    nowPlayingOrigin = new URL(nowPlayingUrl).origin;
  } catch {
    nowPlayingOrigin = "";
  }
}
if (operationsEventsUrl) {
  try {
    operationsOrigin = new URL(operationsEventsUrl).origin;
  } catch {
    operationsOrigin = "";
  }
}
// Cloudflare Web Analytics beacon (auto-injected by Pages).
const connectSrc = ["'self'", shopifyOrigin, "https://shopandson.com", "https://cloudflareinsights.com", nowPlayingOrigin, operationsOrigin]
  .filter(Boolean)
  .join(" ");
const contentSecurityPolicy = [
  "default-src 'self'",
  "script-src 'self' https://static.cloudflareinsights.com",
  "style-src 'self' 'unsafe-inline' https://fonts.googleapis.com",
  "font-src 'self' https://fonts.gstatic.com",
  "img-src 'self' data: https://cdn.shopify.com https://i.scdn.co",
  "media-src 'self' https://cdn.shopify.com",
  `connect-src ${connectSrc}`,
  "frame-src 'self'",
  "object-src 'none'",
  "base-uri 'self'",
  `form-action 'self' ${shopifyOrigin}`,
  "upgrade-insecure-requests",
].join("; ");
---
<!doctype html>
<html lang="en" class:list={[{ landing }]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:site_name" content="&son" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={absolutePageUrl} />
    <meta property="og:image" content={absoluteOgImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImageUrl} />
    <link rel="canonical" href={absolutePageUrl} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={withBase("/favicon.png")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    {
      preloadHeroPoster && (
        <link rel="preload" as="image" href={withBase("/videos/hero-poster.webp")} fetchpriority="high" />
      )
    }
    {
      import.meta.env.PROD && (
        <meta http-equiv="Content-Security-Policy" content={`${contentSecurityPolicy};`} />
      )
    }
    {nowPlayingUrl && <link rel="stylesheet" href={withBase("/styles/now-playing.css")} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin />
    <link rel="preconnect" href={shopifyOrigin} crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anonymous+Pro:ital,wght@0,400;0,700;1,400&family=Roboto+Mono:ital,wght@0,400;0,500;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cardo:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class:list={[{ landing }]} data-open-hour={site.hours.openHour} data-close-hour={site.hours.closeHour}>
    <slot />

    <script>
      import { initializeAnalytics } from "../lib/analytics";
      initializeAnalytics();
    </script>
    <script type="module" src={withBase("/scripts/base.js")}></script>
  </body>
</html>

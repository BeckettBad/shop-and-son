---
import Base from "../layouts/Base.astro";
---

<Base bare title="&son">
  <script>
    const handle = new URLSearchParams(window.location.search).get("handle")?.trim() ?? "";

    import("../lib/url").then(({ withBase }) => {
      location.replace(handle ? withBase(`/?product=${encodeURIComponent(handle)}`) : withBase("/"));
    });
  </script>
</Base>

---
import { withBase } from "../lib/url.ts";

const primaryLinks = [
  { label: "contact", href: "https://shopandson.com/pages/contact" },
  { label: "return policy", href: "https://shopandson.com/pages/customer-service" },
  { label: "about", href: "https://shopandson.com/pages/about" },
  { label: "& son radio", href: "https://shopandson.com/pages/son-radio" },
  { label: "gift card", href: "https://shopandson.com/products/gift-card" },
  { label: "social", href: "https://www.instagram.com/shopandson/" },
];

const policyLinks = [
  { label: "Refund policy", href: "https://shopandson.com/policies/refund-policy" },
  { label: "Privacy policy", href: "https://shopandson.com/policies/privacy-policy" },
  { label: "Terms of service", href: "https://shopandson.com/policies/terms-of-service" },
  { label: "Contact information", href: "https://shopandson.com/policies/contact-information" },
];
---

<footer class="site-footer" aria-label="Footer">
  <section class="footer-newsletter" aria-label="Newsletter">
    <img
      class="footer-mark"
      src={withBase("/images/footer-chronicle.png")}
      alt="& son chronicle"
      loading="lazy"
      decoding="async"
    />
    <p class="footer-tagline">be the first to know about new product, pop ups &amp; the general going ons of &amp; son</p>
    <form class="footer-form" method="post" action="https://shopandson.com/contact#contact_form">
      <input type="hidden" name="form_type" value="customer" />
      <input type="hidden" name="contact[tags]" value="newsletter" />
      <label class="sr-only" for="footer-email">Email</label>
      <div class="footer-field">
        <input id="footer-email" type="email" name="contact[email]" autocomplete="email" placeholder="Email" required />
        <button class="footer-subscribe" type="submit">Subscribe</button>
      </div>
    </form>
  </section>

  <nav class="footer-primary" aria-label="Footer primary links">
    <ul class="footer-linklist">
      {
        primaryLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noopener">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="sub-footer">
    <ul class="footer-policies">
      {
        policyLinks.map((link) => (
          <li>
            <a href={link.href} target="_blank" rel="noopener">
              {link.label}
            </a>
          </li>
        ))
      }
      <li><span class="footer-region">US ($)</span></li>
    </ul>
    <p class="footer-copyright">&copy; 2026 Shop And Son</p>
  </div>
</footer>

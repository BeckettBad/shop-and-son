---
import { objects, site } from "../../data/content.ts";
import { Image } from "astro:assets";
import o1 from "../../assets/blocks/object-01.png";
import o2 from "../../assets/blocks/object-02.png";
import o3 from "../../assets/blocks/object-03.png";
import o4 from "../../assets/blocks/object-04.png";
import FlowerDivider from "../FlowerDivider.astro";

const searchUrl = (n: string) => `${site.shopUrl}/search?q=${encodeURIComponent(n)}`;
// Slide-3 positions (grid auto-flow order = TL, TR, BL, BR).
// Senia Cade takes the slot that was Mark Patrick Harrington (object-03).
const cutouts = [
  { img: o1, pos: "o1", maker: "Senia Cade" },       // top-left  (image swapped with bottom-left)
  { img: o2, pos: "o2", maker: "Danny's Mud Shop" },  // top-right (unchanged)
  { img: o3, pos: "o3", maker: "Shino Takeda" },      // bottom-left (image swapped with top-left)
  { img: o4, pos: "o4", maker: "Binu Binu" },         // bottom-right (unchanged)
];
---
<section class="block objects-v2" id="objects">
  <!-- collage on the LEFT: one perpendicular flower-stem divider behind the objects -->
  <div class="obj-collage">
    <FlowerDivider />
    {cutouts.map((c) => (
      <a class={`obj ${c.pos}`} href={searchUrl(c.maker)} target="_blank" rel="noopener" data-maker={c.maker}>
        <span class="objwrap">
          <Image src={c.img} alt={c.maker} width={c.img.width} height={c.img.height} />
        </span>
      </a>
    ))}
  </div>

  <!-- text on the RIGHT -->
  <div class="right obj-text">
    <div class="title">{objects.title}</div>
    <p class="lede">{objects.meta}</p>
    <a class="shopall" href={`${site.shopUrl}/collections/house`} target="_blank" rel="noopener">Shop All →</a>
  </div>

  <!-- maker label that follows the cursor while over an object -->
  <span class="objcursor" id="objcursor" aria-hidden="true"></span>
</section>

<script>
  const cur = document.getElementById("objcursor");
  if (cur) {
    document.querySelectorAll<HTMLElement>(".objects-v2 .obj").forEach((obj) => {
      obj.addEventListener("mouseenter", () => {
        cur.textContent = obj.dataset.maker || "";
        cur.classList.add("show");
      });
      obj.addEventListener("mouseleave", () => cur.classList.remove("show"));
      obj.addEventListener("mousemove", (e) => {
        cur.style.left = e.clientX + "px";
        cur.style.top = e.clientY + "px";
      });
    });
  }
</script>

---
import { heroMenu } from "../../data/content.ts";
import { getCatalogProducts, type CatalogProduct } from "../../lib/catalog";
import { withBase } from "../../lib/url.ts";

const catalogCollections = Array.from(
  new Set(
    heroMenu.flatMap((section) =>
      section.items.flatMap((item) => [
        ...(item.collection ? [item.collection] : []),
        ...(item.children?.flatMap((child) => (child.collection ? [child.collection] : [])) ?? []),
      ]),
    ),
  ),
);
const catalogEntries = await Promise.all(
  catalogCollections.map(async (collection) => [collection, await getCatalogProducts(collection)] as const),
);
const catalogData: Record<string, CatalogProduct[]> = Object.fromEntries(catalogEntries);
const catalogDataJson = JSON.stringify(catalogData).replace(/</g, "\\u003c");

// Block 1 — desktop: vertical left menu; mobile: horizontal tabs over fullscreen video.
---
<section class="block hero-video" id="hero">
  <video
    class="hero-video__media hero-video__media--desktop"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
  >
    <source src={withBase("/videos/homepage-hero.mp4")} type="video/mp4" />
  </video>

  <video
    class="hero-video__media hero-video__media--mobile"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
  >
    <source src={withBase("/videos/homepage-hero-mobile.mp4")} type="video/mp4" />
  </video>

  <img class="hero__stencil" src={withBase("/images/hero-stencil.png")} alt="" aria-hidden="true" />

  <div class="hero__dj dj-content-wrapper" aria-hidden="true">
    <img class="dj-cutout-image" src={withBase("/images/dj-in-action-cutout.png")} alt="" />
    <span class="music-notes-layer">
      <span class="music-note music-note--single music-note--1" aria-hidden="true">
        <svg viewBox="0 0 24 32" focusable="false">
          <path d="M16 4v18.5a5 5 0 1 1-2-4V8l8-2v4z" />
        </svg>
      </span>
      <span class="music-note music-note--double music-note--2" aria-hidden="true">
        <svg viewBox="0 0 40 32" focusable="false">
          <path d="M13 6v18a5 5 0 1 1-2-4V8l18-3v17a5 5 0 1 1-2-4V9z" />
          <path d="M12 8l18-3" />
        </svg>
      </span>
      <span class="music-note music-note--small music-note--3" aria-hidden="true">
        <svg viewBox="0 0 32 28" focusable="false">
          <path d="M10 5v15a4 4 0 1 1-1.7-3.3V7l13-2v13.5a4 4 0 1 1-1.7-3.2V6.6z" />
        </svg>
      </span>
      <span class="music-note music-note--single music-note--4" aria-hidden="true">
        <svg viewBox="0 0 24 32" focusable="false">
          <path d="M16 4v18.5a5 5 0 1 1-2-4V8l8-2v4z" />
        </svg>
      </span>
      <span class="music-note music-note--double music-note--5" aria-hidden="true">
        <svg viewBox="0 0 40 32" focusable="false">
          <path d="M13 6v18a5 5 0 1 1-2-4V8l18-3v17a5 5 0 1 1-2-4V9z" />
          <path d="M12 8l18-3" />
        </svg>
      </span>
      <span class="music-note music-note--small music-note--6" aria-hidden="true">
        <svg viewBox="0 0 32 28" focusable="false">
          <path d="M10 5v15a4 4 0 1 1-1.7-3.3V7l13-2v13.5a4 4 0 1 1-1.7-3.2V6.6z" />
        </svg>
      </span>
    </span>
  </div>

  <nav class="hero__overlay" aria-label="Site sections">
    <ul class="hero__menu">
      {
        heroMenu.map((section) => (
          <li
            class="hero__menu-section"
            data-hero-dropdown
            data-preorder={section.preorder ? "true" : undefined}
            data-music={section.music ? "true" : undefined}
          >
            <button type="button" class="hero__menu-header" aria-expanded="false">
              {section.label} <span class="hero__menu-toggle">+</span>
            </button>
            {!section.preorder && (
              <ul class="hero__menu-panel">
                {
                  section.items.map((item) => (
                    <li class={`hero__menu-item${item.children && item.children.length > 0 ? " hero__menu-item--group" : ""}`}>
                      {item.collection ? (
                        <button
                          type="button"
                          class="hero__menu-link hero__menu-link--dash"
                          data-shop-all
                          data-collection={item.collection}
                          data-collection-label={item.collectionLabel ?? item.label}
                          aria-pressed="false"
                        >
                          {item.label}{item.suffix ?? ""}
                        </button>
                      ) : item.href ? (
                        <a class="hero__menu-link hero__menu-link--dash" href={item.href}>
                          {item.label}{item.suffix ?? ""}
                        </a>
                      ) : item.children && item.children.length > 0 ? (
                        <button
                          type="button"
                          class="hero__menu-subheader"
                          aria-expanded="false"
                          data-menu-subgroup
                        >
                          {item.label}{item.suffix ?? ""} <span class="hero__menu-subtoggle">+</span>
                        </button>
                      ) : (
                        <span class="hero__menu-link hero__menu-link--dash">
                          {item.label}{item.suffix ?? ""}
                        </span>
                      )}
                      {item.children && item.children.length > 0 && (
                        <ul class="hero__menu-nested">
                          {
                            item.children.map((child) => (
                              <li>
                                {child.collection ? (
                                  <button
                                    type="button"
                                    class="hero__menu-link hero__menu-link--bullet"
                                    data-shop-all
                                    data-collection={child.collection}
                                    data-collection-label={child.collectionLabel ?? child.label}
                                    aria-pressed="false"
                                  >
                                    {child.label}
                                  </button>
                                ) : child.href ? (
                                  <a class="hero__menu-link hero__menu-link--bullet" href={child.href}>
                                    {child.label}
                                  </a>
                                ) : (
                                  <span class="hero__menu-link hero__menu-link--bullet">{child.label}</span>
                                )}
                              </li>
                            ))
                          }
                        </ul>
                      )}
                    </li>
                  ))
                }
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </nav>

  <aside class="hero__catalog" aria-hidden="true">
    <div class="hero__catalog-head">
      <h2 class="hero__catalog-title" data-catalog-title></h2>
      <button type="button" class="hero__catalog-close" data-catalog-close aria-label="Close catalogue">&times;</button>
    </div>
    <div class="hero__catalog-viewport" data-catalog-viewport>
      <div class="hero__catalog-track" data-catalog-track></div>
    </div>
  </aside>

  <aside class="hero__preorder" aria-hidden="true">
    <button type="button" class="hero__preorder-close" data-preorder-close aria-label="Close preorder">&times;</button>
    <div class="hero__preorder-shell" data-preorder-shell>
      <iframe
        class="hero__preorder-frame"
        src={withBase("/preorders/")}
        title="Pre-order"
        loading="lazy"
      ></iframe>
    </div>
  </aside>

  <!-- store info (bottom-left, aligned with the nav column) -->
  <div class="hero-info">
    <p>138 sullivan st,<br />new york, ny 10012</p>
    <p>contact:<br /><a href="mailto:info@shopandson.com">info@shopandson.com</a></p>
  </div>

  <script is:inline type="application/json" id="catalog-data" set:html={catalogDataJson}></script>
</section>

<script>
  interface CatalogProduct {
    title: string;
    vendor: string;
    price: string;
    url: string;
    image?: string;
    imageSrcset?: string;
  }

  const hero = document.querySelector<HTMLElement>(".hero-video");
  const stencil = hero?.querySelector<HTMLElement>(".hero__stencil");
  const dj = hero?.querySelector<HTMLElement>(".hero__dj");
  const catalog = hero?.querySelector<HTMLElement>(".hero__catalog");
  const catalogTitle = hero?.querySelector<HTMLElement>("[data-catalog-title]");
  const catalogViewport = hero?.querySelector<HTMLElement>("[data-catalog-viewport]");
  const catalogTrack = hero?.querySelector<HTMLElement>("[data-catalog-track]");
  const catalogClose = hero?.querySelector<HTMLButtonElement>("[data-catalog-close]");
  const preorder = hero?.querySelector<HTMLElement>(".hero__preorder");
  const preorderShell = hero?.querySelector<HTMLElement>("[data-preorder-shell]");
  const preorderFrame = hero?.querySelector<HTMLIFrameElement>(".hero__preorder-frame");
  const preorderClose = hero?.querySelector<HTMLButtonElement>("[data-preorder-close]");
  const catalogDataNode = hero?.querySelector<HTMLScriptElement>("#catalog-data");
  const collectionButtons = hero
    ? Array.from(hero.querySelectorAll<HTMLButtonElement>("[data-shop-all]"))
    : [];
  const menuSections = hero ? Array.from(hero.querySelectorAll<HTMLElement>("[data-hero-dropdown]")) : [];
  const subgroupToggles = hero ? Array.from(hero.querySelectorAll<HTMLButtonElement>("[data-menu-subgroup]")) : [];
  const desktopPagerQuery = window.matchMedia("(min-width: 761px)");
  const preorderDesktopWidth = 1160;
  const stageDuration = 550;
  let rowIndex = 0;
  let lastRowIndex = 0;
  let isPaging = false;
  let pagingFallback: ReturnType<typeof window.setTimeout> | undefined;
  let stencilReturnCleanup: (() => void) | undefined;
  let stageCleanup: ReturnType<typeof window.setTimeout> | undefined;
  type HeroStage = "landing" | "catalog" | "preorder" | "music";
  type PanelStage = "catalog" | "preorder" | "music";

  let activeStage: HeroStage = "landing";
  let touchStartY: number | null = null;

  const parseCatalogData = (): Record<string, CatalogProduct[]> => {
    try {
      return JSON.parse(catalogDataNode?.textContent ?? "{}") as Record<string, CatalogProduct[]>;
    } catch {
      return {};
    }
  };

  const catalogData = parseCatalogData();

  const setPagingReady = () => {
    isPaging = false;
    if (pagingFallback) {
      window.clearTimeout(pagingFallback);
      pagingFallback = undefined;
    }
  };

  const setRowIndex = (nextIndex: number) => {
    if (!catalogTrack) return;

    rowIndex = Math.max(0, Math.min(nextIndex, lastRowIndex));
    catalogTrack.style.setProperty("--catalog-row-index", String(rowIndex));
  };

  const pageRows = (direction: number) => {
    if (!desktopPagerQuery.matches || !catalogTrack || isPaging) return;

    const nextIndex = Math.max(0, Math.min(rowIndex + direction, lastRowIndex));
    if (nextIndex === rowIndex) return;

    isPaging = true;
    setRowIndex(nextIndex);
    pagingFallback = window.setTimeout(setPagingReady, 560);
  };

  const setActiveButton = (collection: string | null) => {
    collectionButtons.forEach((button) => {
      const isActive = Boolean(collection && button.dataset.collection === collection);
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  };

  const setMenuSubgroupState = (button: HTMLButtonElement, isOpen: boolean) => {
    const group = button.closest(".hero__menu-item--group");
    const toggle = button.querySelector(".hero__menu-subtoggle");
    group?.classList.toggle("is-open", isOpen);
    button.setAttribute("aria-expanded", String(isOpen));
    if (toggle) {
      toggle.textContent = isOpen ? "\u2013" : "+";
    }
  };

  const resetMenuSubgroups = (section: HTMLElement) => {
    const sectionSubgroups = Array.from(section.querySelectorAll<HTMLButtonElement>("[data-menu-subgroup]"));
    sectionSubgroups.forEach((button) => setMenuSubgroupState(button, false));
  };

  const setMenuSectionState = (activeSection: HTMLElement | null) => {
    menuSections.forEach((section) => {
      const isOpen = section === activeSection;
      const trigger = section.querySelector(".hero__menu-header");
      const toggle = section.querySelector(".hero__menu-toggle");
      section.classList.toggle("is-open", isOpen);
      trigger?.setAttribute("aria-expanded", String(isOpen));
      if (toggle) {
        toggle.textContent = isOpen ? "\u2013" : "+";
      }
      if (!isOpen) {
        resetMenuSubgroups(section);
      }
    });
  };

  const getStagePanel = (stage: PanelStage) =>
    stage === "catalog" ? catalog : stage === "preorder" ? preorder : dj;

  const setPanelHidden = (stage: PanelStage, isHidden: boolean) => {
    const panel = getStagePanel(stage);
    panel?.setAttribute("aria-hidden", String(isHidden));
  };

  const setMusicSettled = (isSettled: boolean) => {
    hero?.classList.toggle("is-settled", isSettled && activeStage === "music");
  };

  const clearStageCleanup = () => {
    if (stageCleanup) {
      window.clearTimeout(stageCleanup);
      stageCleanup = undefined;
    }
    catalog?.classList.remove("is-exiting-left");
    preorder?.classList.remove("is-exiting-left");
    dj?.classList.remove("is-exiting-left");
    setMusicSettled(false);
  };

  const clearStencilReturn = () => {
    stencilReturnCleanup?.();
    stencilReturnCleanup = undefined;
    stencil?.style.removeProperty("transition");
    stencil?.style.removeProperty("transform");
  };

  const returnStencilFromRight = () => {
    if (!hero) return;

    const hasActiveStage =
      hero.classList.contains("is-catalog") ||
      hero.classList.contains("is-preorder") ||
      hero.classList.contains("is-music");
    if (!stencil || !hasActiveStage) {
      hero.classList.remove("is-catalog", "is-preorder", "is-music", "is-settled");
      return;
    }

    clearStencilReturn();
    stencil.style.transition = "none";
    stencil.style.transform = "translateX(calc(50vw + 100%))";
    hero.classList.remove("is-catalog", "is-preorder", "is-music", "is-settled");
    void stencil.offsetWidth;

    const finishReturn = (event?: TransitionEvent) => {
      if (event && event.propertyName !== "transform") return;

      stencilReturnCleanup?.();
      stencilReturnCleanup = undefined;
      stencil.style.removeProperty("transition");
      stencil.style.removeProperty("transform");
    };
    const fallback = window.setTimeout(() => finishReturn(), 700);

    stencil.addEventListener("transitionend", finishReturn);
    stencilReturnCleanup = () => {
      window.clearTimeout(fallback);
      stencil.removeEventListener("transitionend", finishReturn);
    };

    window.requestAnimationFrame(() => {
      stencil.style.removeProperty("transition");
      stencil.style.transform = "translateX(0)";
    });
  };

  const resizePreorderFrame = () => {
    if (!preorderShell || !preorderFrame) return;

    if (!desktopPagerQuery.matches) {
      preorderShell.style.removeProperty("--preorder-scale");
      preorderFrame.style.removeProperty("width");
      preorderFrame.style.removeProperty("height");
      return;
    }

    const shellWidth = preorderShell.clientWidth;
    const shellHeight = preorderShell.clientHeight;
    if (shellWidth <= 0 || shellHeight <= 0) return;

    const scale = Math.min(1, shellWidth / preorderDesktopWidth);
    preorderShell.style.setProperty("--preorder-scale", String(scale));
    preorderFrame.style.width = `${preorderDesktopWidth}px`;
    preorderFrame.style.height = `${Math.ceil(shellHeight / scale)}px`;
  };

  const getStageClass = (stage: PanelStage) =>
    stage === "catalog" ? "is-catalog" : stage === "preorder" ? "is-preorder" : "is-music";

  const activatePanel = (stage: PanelStage) => {
    hero?.classList.add(getStageClass(stage));
    setPanelHidden(stage, false);
  };

  const deactivatePanel = (stage: PanelStage) => {
    hero?.classList.remove(getStageClass(stage));
    setPanelHidden(stage, true);
  };

  const transitionToStage = (nextStage: PanelStage, prepareIncoming: () => void) => {
    if (!hero) return;

    clearStageCleanup();
    clearStencilReturn();

    const previousStage = activeStage;
    const previousPanelStage: PanelStage | undefined = previousStage === "landing" ? undefined : previousStage;
    const previousPanel = previousPanelStage ? getStagePanel(previousPanelStage) : undefined;

    if (previousStage === nextStage) {
      previousPanel?.classList.add("is-exiting-left");
      setPanelHidden(nextStage, true);
      stageCleanup = window.setTimeout(() => {
        deactivatePanel(nextStage);
        previousPanel?.classList.remove("is-exiting-left");
        prepareIncoming();
        void previousPanel?.offsetWidth;
        activatePanel(nextStage);
        if (nextStage === "preorder") resizePreorderFrame();
        activeStage = nextStage;
        if (nextStage === "music") {
          stageCleanup = window.setTimeout(() => {
            setMusicSettled(true);
            stageCleanup = undefined;
          }, stageDuration);
          return;
        }
        stageCleanup = undefined;
      }, stageDuration);
      return;
    }

    if (previousPanelStage) {
      previousPanel?.classList.add("is-exiting-left");
      setPanelHidden(previousPanelStage, true);
    }

    prepareIncoming();
    activatePanel(nextStage);
    if (nextStage === "preorder") resizePreorderFrame();
    activeStage = nextStage;

    if (previousPanelStage) {
      stageCleanup = window.setTimeout(() => {
        deactivatePanel(previousPanelStage);
        previousPanel?.classList.remove("is-exiting-left");
        if (nextStage === "music") setMusicSettled(true);
        stageCleanup = undefined;
      }, stageDuration);
      return;
    }

    if (nextStage === "music") {
      stageCleanup = window.setTimeout(() => {
        setMusicSettled(true);
        stageCleanup = undefined;
      }, stageDuration);
    }
  };

  const createProductCard = (product: CatalogProduct) => {
    const card = document.createElement("a");
    card.className = "product-card";
    card.href = product.url;

    const media = document.createElement("span");
    media.className = "product-card__media";
    if (product.image) {
      const image = document.createElement("img");
      image.src = product.image;
      if (product.imageSrcset) {
        image.srcset = product.imageSrcset;
        image.sizes = "(max-width: 760px) 92vw, 20vw";
      }
      image.alt = product.title;
      image.loading = "lazy";
      image.decoding = "async";
      media.append(image);
    }

    const body = document.createElement("span");
    body.className = "product-card__body";

    const title = document.createElement("span");
    title.className = "product-card__title";
    title.textContent = product.title;

    const vendor = document.createElement("span");
    vendor.className = "product-card__vendor";
    vendor.textContent = product.vendor;

    const price = document.createElement("span");
    price.className = "product-card__price";
    price.textContent = product.price;

    body.append(title, vendor, price);
    card.append(media, body);
    return card;
  };

  const renderCatalogContent = (collection: string, label: string) => {
    if (!hero || !catalogTitle || !catalogTrack) return;

    hero.dataset.activeCollection = collection;
    catalogTitle.textContent = label;
    setActiveButton(collection);

    const products = catalogData[collection] ?? [];
    const rows: HTMLDivElement[] = [];
    for (let index = 0; index < products.length; index += 3) {
      const row = document.createElement("div");
      row.className = "hero__catalog-row";
      for (const product of products.slice(index, index + 3)) {
        row.append(createProductCard(product));
      }
      rows.push(row);
    }

    catalogTrack.replaceChildren(...rows);
    lastRowIndex = Math.max(0, rows.length - 1);
    setPagingReady();
    setRowIndex(0);
  };

  const openCatalog = (collection: string, label: string) => {
    if (!hero || !catalog || !catalogTitle || !catalogTrack) return;

    transitionToStage("catalog", () => renderCatalogContent(collection, label));
  };

  const openPreorder = () => {
    if (!hero || !preorder) return;

    delete hero.dataset.activeCollection;
    setActiveButton(null);
    setPagingReady();
    setRowIndex(0);
    transitionToStage("preorder", resizePreorderFrame);
  };

  const openMusic = () => {
    if (!hero || !dj) return;

    delete hero.dataset.activeCollection;
    setActiveButton(null);
    setPagingReady();
    setRowIndex(0);
    transitionToStage("music", () => undefined);
  };

  const closeStage = () => {
    if (!hero) return;

    clearStageCleanup();
    setPagingReady();
    setRowIndex(0);
    returnStencilFromRight();
    delete hero.dataset.activeCollection;
    catalog?.setAttribute("aria-hidden", "true");
    preorder?.setAttribute("aria-hidden", "true");
    dj?.setAttribute("aria-hidden", "true");
    setActiveButton(null);
    activeStage = "landing";
  };

  collectionButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const collection = button.dataset.collection;
      const label = button.dataset.collectionLabel ?? button.textContent?.trim() ?? "";
      if (!collection) return;
      openCatalog(collection, label);
    });
  });

  subgroupToggles.forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.closest(".hero__menu-item--group");
      setMenuSubgroupState(button, !group?.classList.contains("is-open"));
    });
  });

  catalogClose?.addEventListener("click", () => {
    setMenuSectionState(null);
    closeStage();
  });
  preorderClose?.addEventListener("click", () => {
    setMenuSectionState(null);
    closeStage();
  });

  catalogViewport?.addEventListener(
    "wheel",
    (event) => {
      if (!desktopPagerQuery.matches) return;

      event.preventDefault();
      if (Math.abs(event.deltaY) < 8) return;

      pageRows(event.deltaY > 0 ? 1 : -1);
    },
    { passive: false },
  );

  catalogViewport?.addEventListener("touchstart", (event) => {
    if (!desktopPagerQuery.matches) return;

    touchStartY = event.touches[0]?.clientY ?? null;
  });

  catalogViewport?.addEventListener("touchend", (event) => {
    if (!desktopPagerQuery.matches || touchStartY === null) return;

    const touchEndY = event.changedTouches[0]?.clientY ?? touchStartY;
    const deltaY = touchStartY - touchEndY;
    touchStartY = null;
    if (Math.abs(deltaY) < 32) return;

    pageRows(deltaY > 0 ? 1 : -1);
  });

  catalogTrack?.addEventListener("transitionend", (event) => {
    if (event.propertyName === "transform") {
      setPagingReady();
    }
  });

  menuSections.forEach((section) => {
    const trigger = section.querySelector(".hero__menu-header");
    const toggle = section.querySelector(".hero__menu-toggle");
    if (!trigger || !toggle) return;

    trigger.addEventListener("click", () => {
      const isPreorderSection = section.dataset.preorder === "true";
      const isMusicSection = section.dataset.music === "true";
      const isOpen = !section.classList.contains("is-open");

      if (isPreorderSection && isOpen) {
        setMenuSectionState(section);
        openPreorder();
        return;
      }

      if (isMusicSection && isOpen) {
        setMenuSectionState(section);
        openMusic();
        return;
      }

      setMenuSectionState(isOpen ? section : null);
      closeStage();
    });
  });

  const preorderObserver =
    preorderShell && "ResizeObserver" in window
      ? new ResizeObserver(() => resizePreorderFrame())
      : undefined;
  if (preorderShell) {
    preorderObserver?.observe(preorderShell);
    window.addEventListener("resize", resizePreorderFrame);
  }
</script>

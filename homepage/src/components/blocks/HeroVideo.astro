---
import { heroMenu } from "../../data/content.ts";
import { getCatalogProducts, type CatalogProduct } from "../../lib/catalog";
import { withBase } from "../../lib/url.ts";

const catalogCollections = Array.from(
  new Set(
    heroMenu.flatMap((section) =>
      section.items.flatMap((item) => [
        ...(item.collection ? [item.collection] : []),
        ...(item.children?.flatMap((child) => (child.collection ? [child.collection] : [])) ?? []),
      ]),
    ),
  ),
);
const catalogEntries = await Promise.all(
  catalogCollections.map(async (collection) => [collection, await getCatalogProducts(collection)] as const),
);
const catalogData: Record<string, CatalogProduct[]> = Object.fromEntries(catalogEntries);
const catalogDataJson = JSON.stringify(catalogData).replace(/</g, "\\u003c");
const isExternalHref = (href: string) => /^https?:\/\//i.test(href);

// Block 1 — desktop: vertical left menu; mobile: horizontal tabs over fullscreen video.
---
<section class="block hero-video" id="hero">
  <div class="hero__search" data-search>
    <button class="hero__search-toggle" data-search-toggle type="button" aria-label="search">
      <svg class="hero__search-icon" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
        <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" fill="none" stroke-width="1.5" />
        <path d="M12.5 12.5L17 17" stroke="currentColor" fill="none" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
    <input class="hero__search-input" data-search-input type="text" placeholder="search…" aria-label="search products" autocomplete="off" />
  </div>

  <button type="button" class="hero__cart" data-cart-toggle aria-label="Cart">
    <svg focusable="false" class="icon icon-bag" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px"
	 viewBox="0 0 20 20" style="enable-background:new 0 0 24 24;" xml:space="preserve">
<path fill="currentColor" d="M17.200012,5.519043h-3.573059V4.60791c0-2-1.626953-3.626953-3.626953-3.626953S6.373047,2.60791,6.373047,4.60791
	v0.911133H2.799988L1,18.519043h18L17.200012,5.519043z M7.373047,4.60791c0-1.44873,1.178223-2.626953,2.626953-2.626953
	c1.448242,0,2.626953,1.178223,2.626953,2.626953v0.911133H7.373047V4.60791z M3.671082,6.519043h2.701965v1h1v-1h5.253906v1h1v-1
	h2.701965l1.523071,11H2.14801L3.671082,6.519043z"/>
</svg>
    <span class="hero__cart-count" data-cart-count hidden></span>
  </button>

  <video
    class="hero-video__media hero-video__media--desktop"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
  >
    <source src={withBase("/videos/homepage-hero.mp4")} type="video/mp4" />
  </video>

  <video
    class="hero-video__media hero-video__media--mobile"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
  >
    <source src={withBase("/videos/homepage-hero-mobile.mp4")} type="video/mp4" />
  </video>

  <button
    type="button"
    class="hero__stencil"
    data-film-open
    aria-label="about & son"
    style={`--stencil-mask-url:url("${withBase("/images/hero-stencil.png")}")`}
  ></button>

  <div class="hero__dj dj-content-wrapper" aria-hidden="true">
    <img class="dj-cutout-image" src={withBase("/images/dj-in-action-cutout.png")} alt="" />
    <span class="music-notes-layer">
      <span class="music-note music-note--single music-note--1" aria-hidden="true">
        <svg viewBox="0 0 24 32" focusable="false">
          <path d="M16 4v18.5a5 5 0 1 1-2-4V8l8-2v4z" />
        </svg>
      </span>
      <span class="music-note music-note--double music-note--2" aria-hidden="true">
        <svg viewBox="0 0 40 32" focusable="false">
          <path d="M13 6v18a5 5 0 1 1-2-4V8l18-3v17a5 5 0 1 1-2-4V9z" />
          <path d="M12 8l18-3" />
        </svg>
      </span>
      <span class="music-note music-note--small music-note--3" aria-hidden="true">
        <svg viewBox="0 0 32 28" focusable="false">
          <path d="M10 5v15a4 4 0 1 1-1.7-3.3V7l13-2v13.5a4 4 0 1 1-1.7-3.2V6.6z" />
        </svg>
      </span>
      <span class="music-note music-note--single music-note--4" aria-hidden="true">
        <svg viewBox="0 0 24 32" focusable="false">
          <path d="M16 4v18.5a5 5 0 1 1-2-4V8l8-2v4z" />
        </svg>
      </span>
      <span class="music-note music-note--double music-note--5" aria-hidden="true">
        <svg viewBox="0 0 40 32" focusable="false">
          <path d="M13 6v18a5 5 0 1 1-2-4V8l18-3v17a5 5 0 1 1-2-4V9z" />
          <path d="M12 8l18-3" />
        </svg>
      </span>
      <span class="music-note music-note--small music-note--6" aria-hidden="true">
        <svg viewBox="0 0 32 28" focusable="false">
          <path d="M10 5v15a4 4 0 1 1-1.7-3.3V7l13-2v13.5a4 4 0 1 1-1.7-3.2V6.6z" />
        </svg>
      </span>
    </span>
  </div>

  <nav class="hero__overlay" aria-label="Site sections">
    <ul class="hero__menu">
      {
        heroMenu.map((section, index) => (
          <>
            <li
              class="hero__menu-section"
              data-hero-dropdown
              data-preorder={section.preorder ? "true" : undefined}
              data-fam={section.fam ? "true" : undefined}
              data-music={section.music ? "true" : undefined}
            >
              <button type="button" class="hero__menu-header" aria-expanded="false">
                {section.label} <span class="hero__menu-toggle">+</span>
              </button>
              {!section.preorder && !section.fam && (
                <ul class="hero__menu-panel">
                  {
                    section.items.map((item) => (
                      <li class={`hero__menu-item${item.children && item.children.length > 0 ? " hero__menu-item--group" : ""}`}>
                        {item.collection ? (
                          <button
                            type="button"
                            class="hero__menu-link hero__menu-link--dash"
                            data-shop-all
                            data-collection={item.collection}
                            data-collection-label={item.collectionLabel ?? item.label}
                            aria-pressed="false"
                          >
                            {item.label}{item.suffix ?? ""}
                          </button>
                        ) : item.href ? (
                          <a
                            class="hero__menu-link hero__menu-link--dash"
                            href={item.href}
                            target={isExternalHref(item.href) ? "_blank" : undefined}
                            rel={isExternalHref(item.href) ? "noopener" : undefined}
                          >
                            {item.label}{item.suffix ?? ""}
                          </a>
                        ) : item.children && item.children.length > 0 ? (
                          <button
                            type="button"
                            class="hero__menu-subheader"
                            aria-expanded="false"
                            data-menu-subgroup
                          >
                            {item.label}{item.suffix ?? ""} <span class="hero__menu-subtoggle">+</span>
                          </button>
                        ) : (
                          <span class="hero__menu-link hero__menu-link--dash">
                            {item.label}{item.suffix ?? ""}
                          </span>
                        )}
                        {item.children && item.children.length > 0 && (
                          <ul class="hero__menu-nested">
                            {
                              item.children.map((child) => (
                                <li>
                                  {child.collection ? (
                                    <button
                                      type="button"
                                      class="hero__menu-link hero__menu-link--bullet"
                                      data-shop-all
                                      data-collection={child.collection}
                                      data-collection-label={child.collectionLabel ?? child.label}
                                      aria-pressed="false"
                                    >
                                      {child.label}
                                    </button>
                                  ) : child.href ? (
                                    <a
                                      class="hero__menu-link hero__menu-link--bullet"
                                      href={child.href}
                                      target={isExternalHref(child.href) ? "_blank" : undefined}
                                      rel={isExternalHref(child.href) ? "noopener" : undefined}
                                    >
                                      {child.label}
                                    </a>
                                  ) : (
                                    <span class="hero__menu-link hero__menu-link--bullet">{child.label}</span>
                                  )}
                                </li>
                              ))
                            }
                          </ul>
                        )}
                      </li>
                    ))
                  }
                </ul>
              )}
            </li>
            {index === 2 && <li class="hero__menu-break" aria-hidden="true"></li>}
          </>
        ))
      }
    </ul>

    <div class="hero-info">
      <p>138 sullivan st,<br />new york, ny 10012</p>
      <p>contact:<br /><a href="mailto:info@shopandson.com">info@shopandson.com</a></p>
      <p class="hero-info__legal">
        <a href={withBase("/policies/?policy=refund-policy")}>refund policy</a><br />
        <a href={withBase("/policies/?policy=privacy-policy")}>privacy policy</a><br />
        <a href={withBase("/policies/?policy=terms-of-service")}>terms of service</a>
      </p>
    </div>
  </nav>

  <aside class="hero__catalog" aria-hidden="true">
    <div class="hero__catalog-head">
      <h2 class="hero__catalog-title">
        <span class="hero__catalog-title-text" data-catalog-title></span>
        <span class="hero__catalog-description-separator" data-catalog-description-separator hidden>—</span>
        <span class="hero__catalog-description" data-catalog-description hidden></span>
      </h2>
      <button type="button" class="hero__catalog-close" data-catalog-close aria-label="Close catalogue">&times;</button>
    </div>
    <div class="hero__catalog-viewport" data-catalog-viewport>
      <div class="hero__catalog-track" data-catalog-track></div>
    </div>
  </aside>

  <aside class="hero__product" aria-hidden="true">
    <button type="button" class="hero__product-close" data-product-close aria-label="Close product">&times;</button>
    <div class="hero__product-view" data-product-view></div>
  </aside>

  <aside class="hero__preorder" aria-hidden="true">
    <button type="button" class="hero__preorder-close" data-preorder-close aria-label="Close preorder">&times;</button>
    <div class="hero__preorder-shell" data-preorder-shell>
      <iframe
        class="hero__preorder-frame"
        src={withBase("/preorders/")}
        title="Pre-order"
        loading="lazy"
      ></iframe>
    </div>
  </aside>

  <aside class="hero__film" aria-hidden="true">
    <div class="hero__film-frame">
      <video class="hero__film-video" src={withBase("/videos/about-film.mp4")} preload="metadata" playsinline></video>
      <button type="button" class="hero__film-close" data-film-close aria-label="Close">&times;</button>
      <button type="button" class="hero__film-playback" data-film-playback aria-label="Play film">
        <svg class="hero__film-glyph hero__film-glyph--play" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
          <path d="M22 14v36l29-18z"></path>
        </svg>
        <svg class="hero__film-glyph hero__film-glyph--pause" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
          <rect x="18" y="14" width="10" height="36" rx="2"></rect>
          <rect x="36" y="14" width="10" height="36" rx="2"></rect>
        </svg>
      </button>
      <button type="button" class="hero__film-toggle" data-film-mute aria-label="Mute film">sound on</button>
    </div>
  </aside>

  <aside class="hero__fam" aria-hidden="true">
    <img class="hero__fam-image" src={withBase("/images/fam-tattoo.jpg")} alt="& fam" />
    <p class="hero__fam-copy">
      an interview series that takes an in-depth look at designers we carry like you've never seen them before, unless you're related to them.
    </p>
    <p class="hero__fam-kicker">coming soon…</p>
  </aside>

  <script is:inline type="application/json" id="catalog-data" set:html={catalogDataJson}></script>
</section>

<script>
  import { getLiveHeroMenu, type LiveHeroMenuEntry } from "../../lib/menu";
  import { mountProductView, type ProductImageSeed } from "../../lib/product-view";
  import { getCollection, prefetchProduct, type CollectionDetail } from "../../lib/storefront-client";

  interface CatalogProduct {
    handle: string;
    title: string;
    vendor: string;
    price: string;
    url: string;
    available: boolean;
    image?: string;
    imageSrcset?: string;
    imageAspect: number;
  }

  const BASE = import.meta.env.BASE_URL ?? "/";
  const hero = document.querySelector<HTMLElement>(".hero-video");
  const stencil = hero?.querySelector<HTMLElement>(".hero__stencil");
  const dj = hero?.querySelector<HTMLElement>(".hero__dj");
  const catalog = hero?.querySelector<HTMLElement>(".hero__catalog");
  const catalogTitle = hero?.querySelector<HTMLElement>("[data-catalog-title]");
  const catalogDescription = hero?.querySelector<HTMLElement>("[data-catalog-description]");
  const catalogDescriptionSeparator = hero?.querySelector<HTMLElement>("[data-catalog-description-separator]");
  const catalogViewport = hero?.querySelector<HTMLElement>("[data-catalog-viewport]");
  const catalogTrack = hero?.querySelector<HTMLElement>("[data-catalog-track]");
  const catalogClose = hero?.querySelector<HTMLButtonElement>("[data-catalog-close]");
  const productPanel = hero?.querySelector<HTMLElement>(".hero__product");
  const productView = hero?.querySelector<HTMLElement>("[data-product-view]");
  const productClose = hero?.querySelector<HTMLButtonElement>("[data-product-close]");
  const preorder = hero?.querySelector<HTMLElement>(".hero__preorder");
  const preorderShell = hero?.querySelector<HTMLElement>("[data-preorder-shell]");
  const preorderFrame = hero?.querySelector<HTMLIFrameElement>(".hero__preorder-frame");
  const preorderClose = hero?.querySelector<HTMLButtonElement>("[data-preorder-close]");
  const filmPanel = hero?.querySelector<HTMLElement>(".hero__film");
  const filmVideo = hero?.querySelector<HTMLVideoElement>(".hero__film-video");
  const filmPlayback = hero?.querySelector<HTMLButtonElement>("[data-film-playback]");
  const filmMute = hero?.querySelector<HTMLButtonElement>("[data-film-mute]");
  const filmClose = hero?.querySelector<HTMLButtonElement>("[data-film-close]");
  const filmOpen = hero?.querySelector<HTMLButtonElement>("[data-film-open]");
  const famPanel = hero?.querySelector<HTMLElement>(".hero__fam");
  const search = hero?.querySelector<HTMLElement>("[data-search]");
  const searchToggle = hero?.querySelector<HTMLButtonElement>("[data-search-toggle]");
  const searchInput = hero?.querySelector<HTMLInputElement>("[data-search-input]");
  const catalogDataNode = hero?.querySelector<HTMLScriptElement>("#catalog-data");
  const heroMenuElement = hero?.querySelector<HTMLElement>(".hero__menu");
  const menuSections = hero ? Array.from(hero.querySelectorAll<HTMLElement>("[data-hero-dropdown]")) : [];
  const subgroupToggles = hero ? Array.from(hero.querySelectorAll<HTMLButtonElement>("[data-menu-subgroup]")) : [];
  const mobileQuery = window.matchMedia("(max-width: 760px)");
  const desktopQuery = window.matchMedia("(min-width: 761px)");
  const preorderDesktopWidth = 1160;
  const stageDuration = 550;
  const fallbackCardAspect = 0.75;
  const liveCollectionCache = new Map<string, Promise<CollectionDetail | null>>();
  let filmHasStarted = false;
  let stencilReturnCleanup: (() => void) | undefined;
  let stageCleanup: ReturnType<typeof window.setTimeout> | undefined;
  type HeroStage = "landing" | "catalog" | "product" | "preorder" | "music" | "film" | "fam";
  type PanelStage = "catalog" | "product" | "preorder" | "music" | "film" | "fam";
  interface SavedCatalog {
    collection: string;
    label: string;
    scrollTop: number;
  }
  interface OpenProductOptions {
    saveReturnPoint?: boolean;
    seedImage?: ProductImageSeed;
  }

  let activeStage: HeroStage = "landing";
  let activeProductHandle: string | null = null;
  let savedCatalog: SavedCatalog | null = null;
  let catalogScrollRestoreSequence = 0;

  const isCartOpen = () => document.querySelector(".cart-drawer")?.classList.contains("is-open") ?? false;

  const openSearch = () => {
    if (!search || !searchInput) return;

    search.classList.add("is-open");
    window.requestAnimationFrame(() => {
      searchInput.focus();
    });
  };

  const closeSearch = (clearInput = false) => {
    if (!search || !searchInput) return;

    search.classList.remove("is-open");
    if (clearInput) {
      searchInput.value = "";
    }
  };

  const toggleSearch = () => {
    if (search?.classList.contains("is-open")) {
      closeSearch();
      return;
    }

    openSearch();
  };

  const hasTextInputFocus = () => {
    const activeElement = document.activeElement;
    if (!(activeElement instanceof HTMLElement)) return false;

    const tagName = activeElement.tagName.toLowerCase();
    return tagName === "input" || tagName === "textarea" || activeElement.isContentEditable;
  };

  const parseCatalogData = (): Record<string, CatalogProduct[]> => {
    try {
      return JSON.parse(catalogDataNode?.textContent ?? "{}") as Record<string, CatalogProduct[]>;
    } catch {
      return {};
    }
  };

  const catalogData = parseCatalogData();

  const getProductHref = (handle: string) => {
    const base = BASE.replace(/\/$/, "");
    return `${base}/product/?handle=${encodeURIComponent(handle)}`;
  };

  const getHomepageProductUrl = (handle: string) => {
    const url = new URL(location.href);
    url.pathname = BASE;
    url.searchParams.set("product", handle);
    url.hash = "";
    return url;
  };

  const prefetchCatalogProduct = (handle: string) => {
    if (!handle) return;
    void prefetchProduct(handle);
  };

  const getCurrentProductParam = () => new URL(location.href).searchParams.get("product");

  const stripProductParamFromUrl = () => {
    const url = new URL(location.href);
    if (!url.searchParams.has("product")) return;

    url.searchParams.delete("product");
    history.replaceState(null, "", url);
  };

  const getHandleFromProductHref = (href: string) => {
    try {
      return new URL(href, location.href).searchParams.get("handle");
    } catch {
      return null;
    }
  };

  const getCardAspect = (imageAspect: number | undefined) => {
    const aspect = Number(imageAspect);
    return Number.isFinite(aspect) && aspect > 0 ? aspect : fallbackCardAspect;
  };

  const getProductSeedImage = (card: HTMLAnchorElement): ProductImageSeed | undefined => {
    const image = card.querySelector<HTMLImageElement>(".product-card__media img");
    const seedUrl = image?.currentSrc || image?.src;
    if (!image || !seedUrl) return undefined;

    const cardAspect = Number.parseFloat(card.style.getPropertyValue("--card-aspect"));
    const width = image.naturalWidth || undefined;
    const height = image.naturalHeight || undefined;
    const naturalAspect = width && height ? width / height : undefined;
    const aspect = Number.isFinite(cardAspect) && cardAspect > 0 ? cardAspect : naturalAspect;

    return {
      url: seedUrl,
      alt: image.alt,
      width,
      height,
      aspect,
    };
  };

  const getCollectionButtons = () =>
    hero ? Array.from(hero.querySelectorAll<HTMLButtonElement>("[data-shop-all]")) : [];

  const getLiveCollection = (collection: string) => {
    const cachedCollection = liveCollectionCache.get(collection);
    if (cachedCollection) return cachedCollection;

    const liveCollection = getCollection(collection);
    liveCollectionCache.set(collection, liveCollection);
    return liveCollection;
  };

  const getImageCompareKey = (src: string | undefined) => {
    if (!src) return "";

    try {
      return new URL(src).pathname;
    } catch {
      return src.split("?")[0] ?? src;
    }
  };

  const getCatalogScrollTop = () => catalogViewport?.scrollTop ?? 0;

  const restoreCatalogScroll = (scrollTop: number) => {
    if (!catalogViewport) return;

    const targetScrollTop = Math.max(0, scrollTop);
    const restoreSequence = ++catalogScrollRestoreSequence;
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        if (restoreSequence !== catalogScrollRestoreSequence) return;

        catalogViewport.style.scrollBehavior = "auto";
        catalogViewport.scrollTop = targetScrollTop;
        window.requestAnimationFrame(() => {
          if (restoreSequence !== catalogScrollRestoreSequence) return;

          catalogViewport.style.removeProperty("scroll-behavior");
        });
      });
    });
  };

  const resetCatalogScroll = () => {
    restoreCatalogScroll(0);
  };

  const setActiveButton = (collection: string | null) => {
    getCollectionButtons().forEach((button) => {
      const isActive = Boolean(collection && button.dataset.collection === collection);
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  };

  const getMenuLabel = (value: string | null | undefined) =>
    (value ?? "")
      .replace(/[+\u2013-]\s*$/, "")
      .trim()
      .replace(/\s+/g, " ")
      .toLocaleUpperCase("en-US");

  const getMenuSection = (label: string) =>
    menuSections.find((section) => {
      const trigger = section.querySelector<HTMLElement>(".hero__menu-header");
      return getMenuLabel(trigger?.textContent).startsWith(label);
    });

  const getSubgroupList = (section: HTMLElement | undefined, label: string) => {
    if (!section) return null;

    const subgroup = Array.from(section.querySelectorAll<HTMLButtonElement>("[data-menu-subgroup]")).find((button) =>
      getMenuLabel(button.textContent).startsWith(label),
    );
    return subgroup?.closest(".hero__menu-item--group")?.querySelector<HTMLUListElement>(".hero__menu-nested") ?? null;
  };

  const getCollectionEntries = (items: Element[]): LiveHeroMenuEntry[] =>
    items.flatMap((item) => {
      const button = item.querySelector<HTMLButtonElement>("[data-shop-all]");
      const collection = button?.dataset.collection;
      if (!button || !collection) return [];

      const label = getMenuLabel(button.dataset.collectionLabel ?? button.textContent);
      return [
        {
          label,
          collection,
          collectionLabel: label,
        },
      ];
    });

  const entriesMatch = (currentEntries: LiveHeroMenuEntry[], nextEntries: LiveHeroMenuEntry[]) =>
    currentEntries.length === nextEntries.length &&
    currentEntries.every(
      (entry, index) =>
        entry.collection === nextEntries[index]?.collection &&
        entry.collectionLabel === nextEntries[index]?.collectionLabel,
    );

  const createCollectionMenuItem = (entry: LiveHeroMenuEntry, variant: "bullet" | "dash") => {
    const item = document.createElement("li");
    if (variant === "dash") {
      item.className = "hero__menu-item";
    }

    const button = document.createElement("button");
    button.type = "button";
    button.className = `hero__menu-link hero__menu-link--${variant}`;
    button.setAttribute("data-shop-all", "");
    button.dataset.collection = entry.collection;
    button.dataset.collectionLabel = entry.collectionLabel;
    button.setAttribute("aria-pressed", String(hero?.dataset.activeCollection === entry.collection));
    button.classList.toggle("is-active", hero?.dataset.activeCollection === entry.collection);
    button.textContent = entry.label;
    item.append(button);
    return item;
  };

  const reconcileNestedMenuList = (list: HTMLUListElement | null, nextEntries: LiveHeroMenuEntry[]) => {
    if (!list || nextEntries.length === 0) return;

    const currentEntries = getCollectionEntries(Array.from(list.children));
    if (entriesMatch(currentEntries, nextEntries)) return;

    list.replaceChildren(...nextEntries.map((entry) => createCollectionMenuItem(entry, "bullet")));
  };

  const reconcileObjectsMenuList = (section: HTMLElement | undefined, nextEntries: LiveHeroMenuEntry[]) => {
    if (!section || nextEntries.length === 0) return;

    const panel = section.querySelector<HTMLUListElement>(".hero__menu-panel");
    if (!panel) return;

    const items = Array.from(panel.children);
    const shopAllIndex = items.findIndex((item) => item.querySelector("[data-shop-all]"));
    if (shopAllIndex === -1) return;

    const currentLeafItems = items.slice(shopAllIndex + 1);
    const currentEntries = getCollectionEntries(currentLeafItems);
    if (entriesMatch(currentEntries, nextEntries)) return;

    currentLeafItems.forEach((item) => item.remove());
    items[shopAllIndex]?.after(...nextEntries.map((entry) => createCollectionMenuItem(entry, "dash")));
  };

  const hydrateLiveMenu = async () => {
    const liveMenu = await getLiveHeroMenu();
    if (!liveMenu) return;

    const clothesSection = getMenuSection("CLOTHES");
    const objectsSection = getMenuSection("OBJECTS");
    reconcileNestedMenuList(getSubgroupList(clothesSection, "CATEGORIES"), liveMenu.categories);
    reconcileNestedMenuList(getSubgroupList(clothesSection, "DESIGNERS"), liveMenu.designers);
    reconcileObjectsMenuList(objectsSection, liveMenu.objects);
  };

  const setMenuSubgroupState = (button: HTMLButtonElement, isOpen: boolean) => {
    const group = button.closest(".hero__menu-item--group");
    const toggle = button.querySelector(".hero__menu-subtoggle");
    group?.classList.toggle("is-open", isOpen);
    button.setAttribute("aria-expanded", String(isOpen));
    if (toggle) {
      toggle.textContent = isOpen ? "\u2013" : "+";
    }
  };

  const resetMenuSubgroups = (section: HTMLElement) => {
    const sectionSubgroups = Array.from(section.querySelectorAll<HTMLButtonElement>("[data-menu-subgroup]"));
    sectionSubgroups.forEach((button) => setMenuSubgroupState(button, false));
  };

  const setMenuSectionState = (activeSection: HTMLElement | null) => {
    menuSections.forEach((section) => {
      const isOpen = section === activeSection;
      const trigger = section.querySelector(".hero__menu-header");
      const toggle = section.querySelector(".hero__menu-toggle");
      section.classList.toggle("is-open", isOpen);
      trigger?.setAttribute("aria-expanded", String(isOpen));
      if (toggle) {
        toggle.textContent = isOpen ? "\u2013" : "+";
      }
      if (!isOpen) {
        resetMenuSubgroups(section);
      }
    });
  };

  const getStagePanel = (stage: PanelStage) =>
    stage === "catalog"
      ? catalog
      : stage === "product"
        ? productPanel
      : stage === "preorder"
        ? preorder
        : stage === "music"
          ? dj
          : stage === "film"
            ? filmPanel
            : famPanel;

  const setPanelHidden = (stage: PanelStage, isHidden: boolean) => {
    const panel = getStagePanel(stage);
    panel?.setAttribute("aria-hidden", String(isHidden));
  };

  const setMusicSettled = (isSettled: boolean) => {
    hero?.classList.toggle("is-settled", isSettled && activeStage === "music");
  };

  const clearStageCleanup = () => {
    if (stageCleanup) {
      window.clearTimeout(stageCleanup);
      stageCleanup = undefined;
    }
    catalog?.classList.remove("is-exiting-left");
    productPanel?.classList.remove("is-exiting-left");
    preorder?.classList.remove("is-exiting-left");
    dj?.classList.remove("is-exiting-left");
    filmPanel?.classList.remove("is-exiting-left");
    famPanel?.classList.remove("is-exiting-left");
    setMusicSettled(false);
  };

  const clearStencilReturn = () => {
    stencilReturnCleanup?.();
    stencilReturnCleanup = undefined;
    stencil?.style.removeProperty("transition");
    stencil?.style.removeProperty("transform");
  };

  const returnStencilFromRight = () => {
    if (!hero) return;

    const hasActiveStage =
      hero.classList.contains("is-catalog") ||
      hero.classList.contains("is-product") ||
      hero.classList.contains("is-preorder") ||
      hero.classList.contains("is-music") ||
      hero.classList.contains("is-film") ||
      hero.classList.contains("is-fam");
    if (!stencil || !hasActiveStage) {
      hero.classList.remove("is-catalog", "is-product", "is-preorder", "is-music", "is-film", "is-fam", "is-settled");
      return;
    }

    clearStencilReturn();
    stencil.style.transition = "none";
    stencil.style.transform = "translateX(calc(50vw + 100%))";
    hero.classList.remove("is-catalog", "is-product", "is-preorder", "is-music", "is-film", "is-fam", "is-settled");
    void stencil.offsetWidth;

    const finishReturn = (event?: TransitionEvent) => {
      if (event && event.propertyName !== "transform") return;

      stencilReturnCleanup?.();
      stencilReturnCleanup = undefined;
      stencil.style.removeProperty("transition");
      stencil.style.removeProperty("transform");
    };
    const fallback = window.setTimeout(() => finishReturn(), 700);

    stencil.addEventListener("transitionend", finishReturn);
    stencilReturnCleanup = () => {
      window.clearTimeout(fallback);
      stencil.removeEventListener("transitionend", finishReturn);
    };

    window.requestAnimationFrame(() => {
      stencil.style.removeProperty("transition");
      stencil.style.transform = "translateX(0)";
    });
  };

  const resizePreorderFrame = () => {
    if (!preorderShell || !preorderFrame) return;

    if (!desktopQuery.matches) {
      preorderShell.style.removeProperty("--preorder-scale");
      preorderFrame.style.removeProperty("width");
      preorderFrame.style.removeProperty("height");
      return;
    }

    const shellWidth = preorderShell.clientWidth;
    const shellHeight = preorderShell.clientHeight;
    if (shellWidth <= 0 || shellHeight <= 0) return;

    const scale = Math.min(1, shellWidth / preorderDesktopWidth);
    preorderShell.style.setProperty("--preorder-scale", String(scale));
    preorderFrame.style.width = `${preorderDesktopWidth}px`;
    preorderFrame.style.height = `${Math.ceil(shellHeight / scale)}px`;
  };

  const getStageClass = (stage: PanelStage) =>
    stage === "catalog"
      ? "is-catalog"
      : stage === "product"
        ? "is-product"
      : stage === "preorder"
        ? "is-preorder"
        : stage === "music"
          ? "is-music"
          : stage === "film"
            ? "is-film"
            : "is-fam";

  const activatePanel = (stage: PanelStage) => {
    hero?.classList.add(getStageClass(stage));
    setPanelHidden(stage, false);
  };

  const deactivatePanel = (stage: PanelStage) => {
    hero?.classList.remove(getStageClass(stage));
    setPanelHidden(stage, true);
  };

  const transitionToStage = (nextStage: PanelStage, prepareIncoming: () => void) => {
    if (!hero) return;

    clearStageCleanup();
    clearStencilReturn();

    const previousStage = activeStage;
    const previousPanelStage: PanelStage | undefined = previousStage === "landing" ? undefined : previousStage;
    const previousPanel = previousPanelStage ? getStagePanel(previousPanelStage) : undefined;
    if (previousStage === "film") {
      filmVideo?.pause();
      resetFilmMute();
    }

    if (previousStage === nextStage) {
      previousPanel?.classList.add("is-exiting-left");
      setPanelHidden(nextStage, true);
      stageCleanup = window.setTimeout(() => {
        deactivatePanel(nextStage);
        previousPanel?.classList.remove("is-exiting-left");
        prepareIncoming();
        void previousPanel?.offsetWidth;
        activatePanel(nextStage);
        if (nextStage === "preorder") resizePreorderFrame();
        activeStage = nextStage;
        if (nextStage === "music") {
          stageCleanup = window.setTimeout(() => {
            setMusicSettled(true);
            stageCleanup = undefined;
          }, stageDuration);
          return;
        }
        stageCleanup = undefined;
      }, stageDuration);
      return;
    }

    if (previousPanelStage) {
      previousPanel?.classList.add("is-exiting-left");
      setPanelHidden(previousPanelStage, true);
    }

    prepareIncoming();
    activatePanel(nextStage);
    if (nextStage === "preorder") resizePreorderFrame();
    activeStage = nextStage;

    if (previousPanelStage) {
      stageCleanup = window.setTimeout(() => {
        deactivatePanel(previousPanelStage);
        previousPanel?.classList.remove("is-exiting-left");
        if (nextStage === "music") setMusicSettled(true);
        stageCleanup = undefined;
      }, stageDuration);
      return;
    }

    if (nextStage === "music") {
      stageCleanup = window.setTimeout(() => {
        setMusicSettled(true);
        stageCleanup = undefined;
      }, stageDuration);
    }
  };

  const createProductCard = (product: CatalogProduct) => {
    const card = document.createElement("a");
    card.className = "product-card";
    card.href = getProductHref(product.handle);
    card.style.setProperty("--card-aspect", String(getCardAspect(product.imageAspect)));
    card.classList.toggle("is-sold-out", product.available === false);

    const media = document.createElement("span");
    media.className = "product-card__media";
    if (product.image) {
      const image = document.createElement("img");
      image.src = product.image;
      if (product.imageSrcset) {
        image.srcset = product.imageSrcset;
        image.sizes = "(max-width: 420px) 92vw, (max-width: 760px) 46vw, 16vw";
      }
      image.alt = product.title;
      image.loading = "lazy";
      image.decoding = "async";
      media.append(image);
    } else {
      media.style.background = "rgba(247, 244, 235, 0.72)";
    }
    if (product.available === false) {
      const soldOut = document.createElement("span");
      soldOut.className = "product-card__sold-out";
      soldOut.textContent = "sold out";
      media.append(soldOut);
    }

    const body = document.createElement("span");
    body.className = "product-card__body";

    const title = document.createElement("span");
    title.className = "product-card__title";
    title.textContent = product.title;

    const vendor = document.createElement("span");
    vendor.className = "product-card__vendor";
    vendor.textContent = product.vendor;

    const price = document.createElement("span");
    price.className = "product-card__price";
    price.textContent = product.price;

    body.append(title, vendor, price);
    card.append(media, body);
    card.addEventListener("pointerenter", () => prefetchCatalogProduct(product.handle), { passive: true });
    card.addEventListener("pointerdown", () => prefetchCatalogProduct(product.handle), { passive: true });
    card.addEventListener("touchstart", () => prefetchCatalogProduct(product.handle), { passive: true });
    return card;
  };

  const renderCatalogHeader = (title: string, description = "") => {
    if (!catalogTitle || !catalogDescription || !catalogDescriptionSeparator) return;

    const trimmedDescription = description.trim();
    catalogTitle.textContent = title;
    catalogDescription.textContent = trimmedDescription;
    catalogDescription.hidden = !trimmedDescription;
    catalogDescriptionSeparator.hidden = !trimmedDescription;
  };

  const renderCatalogGrid = (products: CatalogProduct[], targetScrollTop = 0) => {
    if (!catalogTrack) return;

    const sorted = [...products].sort(
      (a, b) => Number(a.available === false) - Number(b.available === false),
    );
    catalogTrack.replaceChildren(...sorted.map(createProductCard));
    restoreCatalogScroll(targetScrollTop);
  };

  const getComparableProducts = (products: CatalogProduct[]) =>
    products.map((product) => ({
      handle: product.handle,
      title: product.title,
      vendor: product.vendor,
      price: product.price,
      available: product.available,
      image: getImageCompareKey(product.image),
      imageAspect: getCardAspect(product.imageAspect),
    }));

  const reconcileLiveProducts = (
    liveProducts: CatalogProduct[],
    snapshotProducts: CatalogProduct[],
  ) => {
    const snapshotByHandle = new Map(snapshotProducts.map((product) => [product.handle, product]));

    return liveProducts.map((product) => {
      const snapshotProduct = snapshotByHandle.get(product.handle);
      if (product.image || !snapshotProduct?.image) {
        return {
          ...product,
          imageAspect: getCardAspect(product.imageAspect),
        };
      }

      return {
        ...product,
        image: snapshotProduct.image,
        imageSrcset: snapshotProduct.imageSrcset,
        imageAspect: getCardAspect(snapshotProduct.imageAspect),
      };
    });
  };

  const hasLiveCatalogChanged = (
    liveCollection: CollectionDetail,
    snapshotProducts: CatalogProduct[],
  ) => {
    if (liveCollection.description.trim()) return true;

    return (
      JSON.stringify(getComparableProducts(liveCollection.products)) !==
      JSON.stringify(getComparableProducts(snapshotProducts))
    );
  };

  const renderCatalogContent = (collection: string, label: string) => {
    if (!hero || !catalogTitle || !catalogTrack) return;

    hero.dataset.activeCollection = collection;
    renderCatalogHeader(label);
    setActiveButton(collection);

    const snapshotProducts = catalogData[collection] ?? [];
    renderCatalogGrid(snapshotProducts, 0);

    void getLiveCollection(collection).then((liveCollection) => {
      if (!liveCollection || hero.dataset.activeCollection !== collection) return;

      const refreshScrollTop = getCatalogScrollTop();
      const reconciledLiveCollection: CollectionDetail = {
        ...liveCollection,
        products: reconcileLiveProducts(liveCollection.products, snapshotProducts),
      };
      if (!hasLiveCatalogChanged(reconciledLiveCollection, snapshotProducts)) return;

      renderCatalogHeader(label, reconciledLiveCollection.description);
      renderCatalogGrid(reconciledLiveCollection.products, refreshScrollTop);
    });
  };

  const openCatalog = (collection: string, label: string) => {
    if (!hero || !catalog || !catalogTitle || !catalogTrack) return;

    prepareToLeaveProductForStage();
    transitionToStage("catalog", () => renderCatalogContent(collection, label));
  };

  const openPreorder = () => {
    if (!hero || !preorder) return;

    prepareToLeaveProductForStage();
    delete hero.dataset.activeCollection;
    setActiveButton(null);
    resetCatalogScroll();
    transitionToStage("preorder", resizePreorderFrame);
  };

  const openMusic = () => {
    if (!hero || !dj) return;

    prepareToLeaveProductForStage();
    delete hero.dataset.activeCollection;
    setActiveButton(null);
    resetCatalogScroll();
    transitionToStage("music", () => undefined);
  };

  const openFam = () => {
    if (!hero || !famPanel) return;

    prepareToLeaveProductForStage();
    delete hero.dataset.activeCollection;
    setActiveButton(null);
    resetCatalogScroll();
    transitionToStage("fam", () => undefined);
  };

  const openFilm = () => {
    if (!hero || !filmPanel) return;

    prepareToLeaveProductForStage();
    delete hero.dataset.activeCollection;
    setActiveButton(null);
    resetCatalogScroll();
    transitionToStage("film", () => undefined);
  };

  const openProduct = (handle: string, options: OpenProductOptions | boolean = true) => {
    if (!hero || !productPanel || !productView) return;

    const saveReturnPoint = typeof options === "boolean" ? options : options.saveReturnPoint !== false;
    const seedImage = typeof options === "boolean" ? undefined : options.seedImage;

    productView.replaceChildren();
    productView.removeAttribute("class");

    if (saveReturnPoint && activeStage === "catalog") {
      savedCatalog = {
        collection: hero.dataset.activeCollection ?? "",
        label: catalogTitle?.textContent?.trim() ?? "",
        scrollTop: getCatalogScrollTop(),
      };
    } else {
      savedCatalog = null;
    }

    activeProductHandle = handle;
    transitionToStage("product", () => mountProductView(productView, handle, seedImage ? { seedImage } : undefined));
  };

  const actualCloseProduct = (stripUrl = false) => {
    const catalogReturn = savedCatalog;
    activeProductHandle = null;
    savedCatalog = null;

    if (catalogReturn?.collection) {
      transitionToStage("catalog", () => {
        if (!hero) return;
        hero.dataset.activeCollection = catalogReturn.collection;
        if (catalogTitle) catalogTitle.textContent = catalogReturn.label;
        setActiveButton(catalogReturn.collection);
        restoreCatalogScroll(catalogReturn.scrollTop);
      });
    } else {
      closeStage();
    }

    if (stripUrl) {
      stripProductParamFromUrl();
    }
  };

  const closeProduct = () => {
    if (activeStage !== "product") return;

    if (history.state?.product) {
      history.back();
      return;
    }

    actualCloseProduct(true);
  };

  const prepareToLeaveProductForStage = () => {
    if (activeStage !== "product") return;

    activeProductHandle = null;
    savedCatalog = null;
    stripProductParamFromUrl();
    deactivatePanel("catalog");
    catalog?.classList.remove("is-exiting-left");
  };

  const updateFilmPlayback = () => {
    if (!filmVideo || !filmPlayback) return;

    const isPlaying = !filmVideo.paused && !filmVideo.ended;
    filmPlayback.hidden = isPlaying;
    filmPlayback.classList.toggle("is-paused-after-start", filmHasStarted && !isPlaying);
    filmPlayback.setAttribute("aria-label", isPlaying ? "Pause film" : "Play film");
    filmPlayback.setAttribute("aria-pressed", String(isPlaying));
  };

  const toggleFilmPlayback = () => {
    if (!filmVideo) return;

    if (filmVideo.paused || filmVideo.ended) {
      void filmVideo.play().then(updateFilmPlayback).catch(updateFilmPlayback);
      return;
    }

    filmVideo.pause();
    updateFilmPlayback();
  };

  const updateFilmMute = () => {
    if (!filmVideo || !filmMute) return;

    filmMute.textContent = filmVideo.muted ? "sound off" : "sound on";
    filmMute.setAttribute("aria-label", filmVideo.muted ? "Turn film sound on" : "Mute film");
    filmMute.setAttribute("aria-pressed", String(filmVideo.muted));
  };

  const resetFilmMute = () => {
    if (!filmVideo) return;

    filmVideo.muted = false;
    updateFilmMute();
  };

  const toggleFilmMute = () => {
    if (!filmVideo) return;

    filmVideo.muted = !filmVideo.muted;
    updateFilmMute();
  };

  const closeStage = () => {
    if (!hero) return;

    clearStageCleanup();
    filmVideo?.pause();
    resetFilmMute();
    updateFilmPlayback();
    resetCatalogScroll();
    returnStencilFromRight();
    delete hero.dataset.activeCollection;
    catalog?.setAttribute("aria-hidden", "true");
    productPanel?.setAttribute("aria-hidden", "true");
    preorder?.setAttribute("aria-hidden", "true");
    dj?.setAttribute("aria-hidden", "true");
    filmPanel?.setAttribute("aria-hidden", "true");
    famPanel?.setAttribute("aria-hidden", "true");
    setActiveButton(null);
    activeProductHandle = null;
    savedCatalog = null;
    activeStage = "landing";
  };

  const syncProductStageFromUrl = () => {
    const handle = getCurrentProductParam();
    if (handle) {
      if (activeStage !== "product" || activeProductHandle !== handle) {
        openProduct(handle, activeStage === "catalog");
      }
      return;
    }

    if (activeStage === "product") {
      actualCloseProduct();
    }
  };

  heroMenuElement?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const button = target.closest<HTMLButtonElement>("[data-shop-all]");
    if (!button || !heroMenuElement.contains(button)) return;

    const collection = button.dataset.collection;
    const label = button.dataset.collectionLabel ?? button.textContent?.trim() ?? "";
    if (!collection) return;

    openCatalog(collection, label);
    if (mobileQuery.matches) {
      setMenuSectionState(null);
    }
  });

  subgroupToggles.forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.closest(".hero__menu-item--group");
      setMenuSubgroupState(button, !group?.classList.contains("is-open"));
    });
  });

  catalogClose?.addEventListener("click", () => {
    setMenuSectionState(null);
    closeStage();
  });
  productClose?.addEventListener("click", closeProduct);
  preorderClose?.addEventListener("click", () => {
    setMenuSectionState(null);
    closeStage();
  });
  filmClose?.addEventListener("click", () => {
    setMenuSectionState(null);
    closeStage();
  });
  filmOpen?.addEventListener("click", () => {
    if (activeStage !== "landing") return;

    setMenuSectionState(null);
    openFilm();
  });
  filmVideo?.addEventListener("click", toggleFilmPlayback);
  filmVideo?.addEventListener("play", () => {
    filmHasStarted = true;
    updateFilmPlayback();
  });
  filmVideo?.addEventListener("pause", updateFilmPlayback);
  filmVideo?.addEventListener("ended", updateFilmPlayback);
  filmPlayback?.addEventListener("click", toggleFilmPlayback);
  filmMute?.addEventListener("click", toggleFilmMute);
  resetFilmMute();
  updateFilmPlayback();

  catalogTrack?.addEventListener("click", (event) => {
    if (!(event instanceof MouseEvent)) return;

    const target = event.target;
    if (!(target instanceof Element)) return;

    const link = target.closest<HTMLAnchorElement>(".product-card[href]");
    if (!link || !catalogTrack.contains(link)) return;
    if (
      event.defaultPrevented ||
      event.button !== 0 ||
      event.metaKey ||
      event.ctrlKey ||
      event.shiftKey ||
      event.altKey
    ) {
      return;
    }

    const handle = getHandleFromProductHref(link.href);
    if (!handle) return;

    event.preventDefault();
    history.pushState({ product: handle }, "", getHomepageProductUrl(handle));
    openProduct(handle, { seedImage: getProductSeedImage(link) });
  });

  window.addEventListener("popstate", syncProductStageFromUrl);
  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || activeStage !== "product") return;
    if (isCartOpen()) return;

    event.preventDefault();
    closeProduct();
  });
  searchToggle?.addEventListener("click", toggleSearch);
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && search?.classList.contains("is-open")) {
      event.preventDefault();
      closeSearch(true);
      return;
    }

    if (event.key !== "/" || event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) return;
    if (hasTextInputFocus() || isCartOpen()) return;

    event.preventDefault();
    openSearch();
  });
  document.addEventListener("pointerdown", (event) => {
    if (!search?.classList.contains("is-open") || !searchInput || searchInput.value.trim()) return;
    const target = event.target;
    if (target instanceof Node && search.contains(target)) return;

    closeSearch();
  });

  menuSections.forEach((section) => {
    const trigger = section.querySelector(".hero__menu-header");
    const toggle = section.querySelector(".hero__menu-toggle");
    if (!trigger || !toggle) return;

    trigger.addEventListener("click", () => {
      const isPreorderSection = section.dataset.preorder === "true";
      const isFamSection = section.dataset.fam === "true";
      const isMusicSection = section.dataset.music === "true";
      const isOpen = !section.classList.contains("is-open");

      if (isPreorderSection && isOpen) {
        setMenuSectionState(section);
        openPreorder();
        return;
      }

      if (isMusicSection && isOpen) {
        setMenuSectionState(section);
        openMusic();
        return;
      }

      if (isFamSection && isOpen) {
        setMenuSectionState(section);
        openFam();
        return;
      }

      setMenuSectionState(isOpen ? section : null);
      if (!mobileQuery.matches) {
        closeStage();
      }
    });
  });

  const preorderObserver =
    preorderShell && "ResizeObserver" in window
      ? new ResizeObserver(() => resizePreorderFrame())
      : undefined;
  if (preorderShell) {
    preorderObserver?.observe(preorderShell);
    window.addEventListener("resize", resizePreorderFrame);
  }
  void hydrateLiveMenu();
  syncProductStageFromUrl();
</script>

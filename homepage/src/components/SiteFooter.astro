---
import { withBase } from "../lib/url.ts";

const shopDomain = import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN ?? "";
const sfToken = import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_API_TOKEN ?? "";
const sfVersion = "2025-01";

// Site-wide footer: the &son Chronicle masthead over a taupe panel with the
// newsletter signup. Rendered on every page via Base, reachable by scrolling
// to the bottom of the page. The subscribe interaction lives in base.js
// (bundled) because the prod CSP blocks inline scripts.
---
<footer class="site-footer" data-site-footer>
  <div class="site-footer__panel">
    <img
      class="site-footer__chronicle"
      src={withBase("/images/chronicle-neon.png")}
      alt={`The &son Chronicle`}
      width="1184"
      height="602"
      loading="lazy"
      decoding="async"
    />
    <form
      class="site-footer__form"
      data-subscribe-form
      data-shop-domain={shopDomain}
      data-sf-token={sfToken}
      data-sf-version={sfVersion}
    >
      <input
        class="site-footer__email"
        type="email"
        name="email"
        required
        placeholder="email"
        aria-label="email"
        autocomplete="email"
        data-subscribe-email
      />
      <button class="site-footer__subscribe" type="submit" data-subscribe-btn>subscribe</button>
    </form>
  </div>
</footer>

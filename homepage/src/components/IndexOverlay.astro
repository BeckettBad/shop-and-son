---
import { catalog } from "../data/content.ts";
---
<div class="overlay" id="overlay">
  <h2>{catalog.title}</h2>
  <div class="sub" set:html={catalog.sub} />
  <div class="catalog">
    {catalog.entries.map((e) =>
      e.section ? (
        <div class="row sec">{e.section}</div>
      ) : (
        <div class="row"><span class="num">{e.num}</span>{e.text}</div>
      ),
    )}
  </div>
</div>

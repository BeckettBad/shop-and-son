# Shopify config for the homepage. Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real keys.

# Store domain (custom or *.myshopify.com).
SHOPIFY_STORE_DOMAIN=shopandson.com

# Public site origin/base. Defaults preserve the GitHub Pages dev deployment.
# For production cutover, set PUBLIC_SITE_ORIGIN=https://shopandson.com and
# PUBLIC_BASE_PATH=/.
# PUBLIC_SITE_ORIGIN=https://beckettbad.github.io
# PUBLIC_BASE_PATH=/shop-and-son

# Storefront API access token (PUBLIC, read-only) — used by the front-end to
# display products. Shopify admin → Settings → Apps and sales channels →
# Develop apps → (app) → Storefront API → install → copy token.
SHOPIFY_STOREFRONT_API_TOKEN=

# Client-side Storefront API config (PUBLIC, read-only) — used by browser code.
# For production cutover, set PUBLIC_SHOPIFY_STORE_DOMAIN=shop-and-son.myshopify.com.
# PUBLIC_SHOPIFY_STORE_DOMAIN=
# PUBLIC_SHOPIFY_STOREFRONT_API_TOKEN=

# Optional — Cloudflare Worker's base URL for the MUSIC stage now-playing
# display. A full /now URL also works. Leave unset to render the homepage
# exactly as it does without the now-playing feature.
# PUBLIC_NOW_PLAYING_URL=

# Admin API app credentials (PRIVATE, server/build-time only — never in a built
# page). Only needed if a task uses the Admin API. Prefer the Storefront token.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Optional — Storefront API version (defaults to 2025-01).
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# Optional newsletter endpoint override. When unset, the homepage derives `/subscribe` from
# PUBLIC_NOW_PLAYING_URL. Shopify Admin credentials belong only in Worker secrets, never here.
# PUBLIC_SUBSCRIBE_URL=

# Optional privacy-minimized operations collector. The only accepted value is
# the pinned production endpoint below. When unset or different, analytics is a no-op.
# PUBLIC_OPERATIONS_EVENTS_URL=https://operations.shopandson.com/v1/events

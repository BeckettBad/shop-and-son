---
import { withBase } from "../lib/url.ts";
// Footer replicated from shopandson.com (design only; # placeholders, static form).
const wave = "M0 15 C100 2 200 2 300 15 C400 28 500 28 600 15 C700 2 800 2 900 15 C1000 28 1100 28 1200 15";
const links = ["contact", "return policy", "about", "& son radio", "gift card", "social"];
const policies = ["Refund policy", "Privacy policy", "Terms of service", "Contact information"];
---
<svg class="footer-wave" viewBox="0 0 1200 30" preserveAspectRatio="none" aria-hidden="true">
  <path d={wave} fill="none" stroke="currentColor" stroke-width="2" />
</svg>

<footer class="site-footer">
  <!-- newsletter block (centered): image → italic subheading → email/subscribe -->
  <div class="footer-newsletter">
    <img class="footer-mark" src={withBase("/images/chronicle-outline.png")} alt="Shop And Son" width="280" height="142" />
    <div class="footer-subheading">
      <p><em>be the first to know about new product, pop ups &amp; the general going ons of &amp; son</em></p>
    </div>
    <form class="footer-form" onsubmit="return false">
      <div class="footer-field">
        <input type="email" id="footer-email" placeholder="Email" aria-label="Email" autocomplete="email" />
        <button type="button" class="footer-subscribe" aria-label="Subscribe">Subscribe</button>
      </div>
    </form>
  </div>

  <!-- primary link list (centered, horizontal) -->
  <ul class="footer-linklist" role="list">
    {links.map((l) => <li><a href="#">{l}</a></li>)}
  </ul>

  <!-- sub-footer: two columns — policies + currency (left), copyright (right) -->
  <div class="sub-footer">
    <ul class="footer-policies" role="list">
      {policies.map((p) => <li><a href="#">{p}</a></li>)}
      <li><button type="button" class="market-selector">US ($)</button></li>
    </ul>
    <span class="footer-copyright">© 2026 Shop And Son</span>
  </div>
</footer>

---
import { vault } from "../../data/content.ts";
import { withBase } from "../../lib/url.ts";
const wave = "M0 15 C100 2 200 2 300 15 C400 28 500 28 600 15 C700 2 800 2 900 15 C1000 28 1100 28 1200 15";
---
<section class="block vault" id="vault">
  <svg class="wave t" viewBox="0 0 1200 30" preserveAspectRatio="none" aria-hidden="true">
    <path d={wave} fill="none" stroke="#fff" stroke-width="2" />
  </svg>

  <!-- text on the LEFT (flipped from v1) -->
  <div class="right vault-text">
    <div class="kicker">{vault.kicker}</div>
    <div class="title">The Vintage<br />Vault</div>
    <p class="lede" style="font-size:16px">Clothes ~ Books ~ Records</p>
    <p class="vault-note">Available in store only.<br />New pieces weekly.</p>
    <span class="instore">in store only</span>
    <div class="scroll-hint"><span class="scroll-hint__arrow">↓</span></div>
  </div>

  <!-- black reveal-box on the RIGHT: hover reveals the neon sign -->
  <div class="vbox">
    <img src={withBase("/images/blocks/vault.jpg")} alt="inside the vault" />
    <span class="neon">{vault.neon}</span>
    <span class="vhint">hover to reveal the neon sign</span>
  </div>

  <svg class="wave b" viewBox="0 0 1200 30" preserveAspectRatio="none" aria-hidden="true">
    <path d={wave} fill="none" stroke="#fff" stroke-width="2" />
  </svg>
</section>

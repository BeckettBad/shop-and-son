---
import { music } from "../../data/content.ts";
import { Image } from "astro:assets";
import djImg from "../../assets/blocks/music-dj.jpg";
// Starts off-air: the live Spotify "currently playing" feed needs a small backend
// (store-account OAuth) wired later. Until then this is the graceful fallback.
---
<section class="block offair music-v2" id="music">
  <!-- text LEFT -->
  <div class="right music-text">
    <div class="title">Music</div>
    <p class="lede" style="margin-top:-10px">& son official playlist</p>

    <div class="nowplaying" id="np">
      <div class="bt"><span>now playing · in store</span><span id="np-status">off air</span></div>
      <div class="song" id="np-song">official playlist</div>
      <div class="artist" id="np-artist">&amp; son radio</div>
      <div class="eq"><i></i><i></i><i></i><i></i><i></i></div>
    </div>
    <p class="np-src">↳ mirrors the shop via Spotify — display only, no audio streamed</p>
  </div>

  <!-- music-dj image RIGHT, inset within the panel -->
  <div class="music-img">
    <Image src={djImg} alt="DJ at the wooden speaker booth" width={djImg.width} height={djImg.height} />
  </div>
</section>

<script>
  // The reactive-woofer overlay element was removed; the now-playing/woofer
  // logic is left intact for when the Spotify backend lands — without the
  // #woofer element this simply no-ops.
  const wf = document.getElementById("woofer");
  const section = document.getElementById("music");
  if (wf && section) {
    new IntersectionObserver(
      (entries) => entries.forEach((e) => { wf.style.opacity = e.isIntersecting ? "1" : "0"; }),
      { threshold: 0.4 },
    ).observe(section);
  }
</script>

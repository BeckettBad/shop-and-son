---
// The preorder site's opening, brought in as a homepage block.
// Images are referenced from the LIVE preorder site so they share one source:
// edit public/preorders/images/* (the preorder site's assets) and both update.
const preordersUrl = "https://beckettbad.github.io/shop-and-son/preorders/";
const imgBase = "https://beckettbad.github.io/shop-and-son/preorders/images";
// all garment images, in the same order as the preorder site
const slides = [
  { file: "hero.jpg", label: "front" },
  { file: "fabric.jpg", label: "outer fabric" },
  { file: "lining.jpg", label: "lining" },
  { file: "hardware.jpg", label: "hardware" },
  { file: "features-1.jpg", label: "pocket" },
  { file: "features-2.jpg", label: "back" },
];
const sizes = ["s", "m", "l", "xl"];
---
<section class="block preorders-v2" id="preorders">
  <!-- garment image carousel (LEFT) -->
  <div class="left po-carousel">
    <img class="po-slide" id="poSlide" src={`${imgBase}/${slides[0].file}`} alt="the benny blouson — pre-order" />
    <div class="tint"></div>
    <button class="po-arrow po-prev" id="poPrev" type="button" aria-label="previous image">‹</button>
    <button class="po-arrow po-next" id="poNext" type="button" aria-label="next image">›</button>
    <div class="po-caption"><span id="poLabel">{slides[0].label}</span><span class="po-count"><span id="poIdx">1</span> / {slides.length}</span></div>
  </div>

  <!-- drop info (RIGHT) -->
  <div class="right preorder-text">
    <div class="po-status">week 01 · pre-order open</div>
    <div class="title">The Benny Blouson</div>
    <div class="po-sizes" id="poSizes">
      {sizes.map((s) => <button class="po-size" type="button" data-size={s}>{s}</button>)}
    </div>
    <a class="po-cta" href={preordersUrl} target="_blank" rel="noopener">pre-order now · $495</a>
    <p class="po-ship">ships in 6-8 weeks</p>
  </div>
</section>

<script is:inline define:vars={{ imgBase, slides }}>
  (() => {
    const slide = document.getElementById("poSlide");
    const label = document.getElementById("poLabel");
    const idx = document.getElementById("poIdx");
    let i = 0;
    const show = (n) => {
      i = (n + slides.length) % slides.length;
      slide.src = `${imgBase}/${slides[i].file}`;
      slide.alt = `the benny blouson — ${slides[i].label}`;
      label.textContent = slides[i].label;
      idx.textContent = String(i + 1);
    };
    document.getElementById("poPrev")?.addEventListener("click", () => show(i - 1));
    document.getElementById("poNext")?.addEventListener("click", () => show(i + 1));

    // size selector (visual selection only)
    const wrap = document.getElementById("poSizes");
    wrap?.addEventListener("click", (e) => {
      const btn = e.target.closest(".po-size");
      if (!btn) return;
      wrap.querySelectorAll(".po-size").forEach((x) => x.classList.remove("selected"));
      btn.classList.add("selected");
    });
  })();
</script>

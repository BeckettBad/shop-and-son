---
// Perpendicular flower-stem divider for the objects grid.
// One SVG: a vertical and a horizontal hand-drawn stem that meet at the exact
// centre (50,50); the hand-drawn flower asset caps the four outer tips.
import { Image } from "astro:assets";
import flower from "../assets/blocks/flower.png";
---
<div class="flower-divider" aria-hidden="true">
  <svg class="fd-stems" viewBox="0 0 100 100" preserveAspectRatio="none">
    <!-- both paths pass through 50,50 so the crossing is one clean point -->
    <path d="M50 5 C46.5 24 53.5 38 50 50 C46.5 62 53.5 76 50 95" />
    <path d="M5 50 C24 46.5 38 53.5 50 50 C62 46.5 76 53.5 95 50" />
  </svg>
  <Image class="fd-flower fd-top" src={flower} width={flower.width} height={flower.height} alt="" />
  <Image class="fd-flower fd-bottom" src={flower} width={flower.width} height={flower.height} alt="" />
  <Image class="fd-flower fd-left" src={flower} width={flower.width} height={flower.height} alt="" />
  <Image class="fd-flower fd-right" src={flower} width={flower.width} height={flower.height} alt="" />
</div>

# archived, out-of-scope material (retired generations, shelved homepage-v3,
# raw asset masters, scratch docs). Kept on disk so it can be drawn upon, but
# out of version control to keep the tracked scope = the homepage + deploy.
archive/

# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production
operations/.dev.vars
operations/.dev.vars.*

# local Operations Worker state and sensitive D1 exports
operations/.wrangler/
operations/backups/

# Python relay bytecode
__pycache__/
*.pyc

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# personal Claude Code settings (not shared with the public repo)
.claude/settings.local.json

# monitor runtime state (logs, last-status, test artifacts)
ops/.state/

---
const clothesSubsections = [
	{ label: 'jackets / outerwear', href: '#' },
	{ label: 'shirts with buttons / snaps', href: '#' },
	{ label: 'knitwear', href: '#' },
	{ label: 'tees', href: '#' },
	{ label: 'trousers', href: '#' },
	{ label: 'shorts', href: '#' },
	{ label: 'shoes', href: '#' },
];

const dropdownItems = [
	{ label: 'CLOTHES', subsections: clothesSubsections },
	{ label: 'OBJECTS', subsections: [] },
	{ label: 'MUSIC', subsections: [] },
	{ label: 'VINTAGE', subsections: [] },
	{ label: 'PREORDERS', subsections: [] },
	{ label: '& FAM', subsections: [] },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>&son</title>
		<style is:global>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				height: 100%;
				overflow: hidden;
				background: #efebe2;
				color: #2e2a26;
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				font-weight: 300;
				font-size: 13px;
				line-height: 1.45;
				-webkit-font-smoothing: antialiased;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			a:hover {
				text-decoration: underline;
			}

			button {
				font: inherit;
				color: inherit;
				background: none;
				border: none;
				padding: 0;
				margin: 0;
				cursor: pointer;
				text-align: left;
			}

			.landing {
				position: relative;
				width: 100%;
				height: 100%;
				min-height: 100vh;
				min-height: 100dvh;
			}

			.landing__video {
				position: fixed;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				z-index: 0;
				pointer-events: none;
			}

			.landing__nav,
			.landing__info {
				position: fixed;
				left: 6vw;
				z-index: 1;
			}

			.landing__nav {
				top: 10.7%;
			}

			.landing__info {
				bottom: 10%;
			}

			.nav-list,
			.nav-sublist {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.nav-item + .nav-item {
				margin-top: 0;
			}

			.nav-trigger {
				display: block;
				text-transform: uppercase;
				letter-spacing: 0.01em;
			}

			.nav-trigger:hover {
				text-decoration: underline;
			}

			.nav-sublist {
				display: none;
				padding-left: 1.2em;
				margin-top: 0;
			}

			.nav-item.is-open .nav-sublist {
				display: block;
			}

			.nav-sublist a {
				display: block;
				text-transform: none;
			}

			.nav-chronicle {
				display: block;
				text-transform: uppercase;
				letter-spacing: 0.01em;
			}

			.info-block p {
				margin: 0;
			}

			.info-block p + p {
				margin-top: 1.45em;
			}
		</style>
	</head>
	<body>
		<main class="landing">
			<video
				class="landing__video"
				autoplay
				muted
				loop
				playsinline
				aria-hidden="true"
			>
				<source src="/videos/new-about-homepage.mp4" type="video/mp4" />
			</video>

			<nav class="landing__nav" aria-label="Site sections">
				<ul class="nav-list">
					{
						dropdownItems.map((item) => (
							<li class="nav-item" data-dropdown>
								<button type="button" class="nav-trigger" aria-expanded="false">{item.label} +</button>
								{item.subsections.length > 0 && (
									<ul class="nav-sublist">
										{item.subsections.map((sub) => (
											<li>
												<a href={sub.href}>{sub.label}</a>
											</li>
										))}
									</ul>
								)}
							</li>
						))
					}
					<li class="nav-item">
						<span class="nav-chronicle">& SON CHRONICLE</span>
					</li>
				</ul>
			</nav>

			<div class="landing__info">
				<div class="info-block">
					<p>
						Mostly clothes,<br />
						some objects,<br />
						and a little music
					</p>
					<p>
						138 sullivan st,<br />
						new york, ny 10012
					</p>
					<p>
						contact:<br />
						<a href="mailto:info@shopandson.com">info@shopandson.com</a>
					</p>
				</div>
			</div>
		</main>

		<script>
			document.querySelectorAll('[data-dropdown]').forEach((item) => {
				const trigger = item.querySelector('.nav-trigger');
				if (!trigger) return;

				const baseLabel = trigger.textContent.replace(/\s[+\u2013-]$/, '');

				trigger.addEventListener('click', () => {
					const isOpen = item.classList.toggle('is-open');
					trigger.setAttribute('aria-expanded', String(isOpen));
					trigger.textContent = isOpen ? `${baseLabel} \u2013` : `${baseLabel} +`;
				});
			});
		</script>
	</body>
</html>
